estination=123+far+away+street,+123456+-+Vancouver+BC"},image:{src:"https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&q=80",alt:"Contact us"},imagePosition:"right"},versionedSchema:fo,colorTokensSchema:eP.colorTokensSchema}),f9=fH({id:"cta-background-image",name:"Background Image CTA",description:"A call-to-action section with a background image, heading, description, and buttons.",type:"cta",visualConfigPresets:[{textAlignment:"center"},{textAlignment:"split"}],exampleConfig:{heading:"Get the Yard You Want Today!",description:"Transform your outdoor space into a vibrant sanctuary. From lush blooms to timeless layouts, we'll bring beauty and balance to your garden.",backgroundImage:{src:"https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=1920",alt:"Professional gardener tending to plants in a beautiful garden"},buttons:[{label:"Talk to an Expert",href:"#",actionType:"section"},{label:"Get a Free Quote",href:"#",actionType:"section"}],textAlignment:"center",showButtons:!0},versionedSchema:fn,colorTokensSchema:eB.colorTokensSchema}),f8=fH({id:"cta-basic",name:"Basic CTA",description:"A simple call-to-action section with heading, description, and buttons.",type:"cta",visualConfigPresets:[{textAlignment:"center"},{textAlignment:"split"}],exampleConfig:{heading:"Get the Yard You Want Today!",description:"Transform your outdoor space into a vibrant sanctuary. From lush blooms to timeless layouts, we'll bring beauty and balance to your garden.",buttons:[{label:"Talk to an Expert",href:"#",actionType:"section"},{label:"Get a Free Quote",href:"#",actionType:"section"}],textAlignment:"center",showButtons:!0},versionedSchema:fi,colorTokensSchema:eE.colorTokensSchema}),ye=fH({id:"cta-card",name:"Card CTA",description:"A call-to-action section styled as a card with heading, description, and buttons.",type:"cta",visualConfigPresets:[{textAlignment:"center"},{textAlignment:"split"}],exampleConfig:{heading:"Get the Yard You Want Today!",description:"Transform your outdoor space into a vibrant sanctuary. From lush blooms to timeless layouts, we’ll bring beauty and balance to your garden.",buttons:[{label:"Talk to an Expert",href:"#",actionType:"section"},{label:"Get a Free Quote",href:"#",actionType:"section"}],textAlignment:"center",showButtons:!0},versionedSchema:fr,colorTokensSchema:eF.colorTokensSchema}),yt=fH({id:"cta-card-2",name:"Card CTA 2",description:"A centered call-to-action section with a prominent card container.",type:"cta",visualConfigPresets:[{textAlignment:"center"},{textAlignment:"left"}],exampleConfig:{heading:"Let's start building a brighter financial future together.",description:"We're here to help you manage your finances with smart planning and investing tips.",buttons:[{label:"Get Started",href:"#",actionType:"section"}],textAlignment:"center",showButtons:!0},versionedSchema:fs,colorTokensSchema:eU.colorTokensSchema}),ya=fH({id:"faq-accordion",name:"FAQ Accordion",description:"A frequently asked questions section with an accordion layout.",type:"faq",visualConfigPresets:[{contentAlignment:"center"},{contentAlignment:"split"}],exampleConfig:{kicker:"FAQ",heading:"Frequently asked questions",description:"If you have any further questions, please contact us.",buttons:[],items:[{question:"What services do you offer for landscape design and maintenance?",answer:"We offer a variety of services for landscape design and maintenance, including custom garden design, lawn care, tree and shrub planting, irrigation system installation, and seasonal clean-up. Our team is dedicated to creating beautiful outdoor spaces that suit your needs and preferences."},{question:"What is the best time to plant a garden?",answer:"The best time to plant a garden depends on your location and the types of plants you want to grow. Generally, spring and fall are ideal for most plants, as temperatures are moderate and rainfall is more consistent. However, some plants thrive in summer or winter, so it's important to research the specific requirements of your chosen plants."},{question:"How do I maintain my landscape throughout the year?",answer:"Maintaining your landscape throughout the year involves regular tasks such as mowing, watering, fertilizing, pruning, and mulching. In spring, focus on planting and fertilizing. Summer requires consistent watering and pest control. Fall is the time for cleanup and preparation for winter. Winter maintenance includes protecting plants from frost and planning for the next growing season."},{question:"What types of plants thrive in my area?",answer:"The types of plants that thrive in your area depend on your climate zone, soil type, and sun exposure. Native plants are often the best choice as they are adapted to local conditions and require less maintenance. Consider consulting with a local nursery or landscape professional to identify plants that will flourish in your specific environment."},{question:"How can I create a sustainable garden?",answer:"Creating a sustainable garden involves choosing native plants, using organic fertilizers and pest control methods, conserving water through efficient irrigation systems and mulching, composting yard waste, and encouraging beneficial insects and wildlife. These practices help create a healthy ecosystem while reducing environmental impact."}],contentAlignment:"center",showButtons:!0},versionedSchema:fc,colorTokensSchema:eK.colorTokensSchema}),yo=fH({id:"faq-accordion-image",name:"FAQ Accordion with Image",description:"A frequently asked questions section with an accordion layout and an image on the right side.",type:"faq",visualConfigPresets:[{}],exampleConfig:{heading:"Frequently asked questions",items:[{question:"What services do you offer for landscape design and maintenance?",answer:"We offer a variety of services for landscape design and maintenance, including custom garden design, lawn care, tree and shrub planting, irrigation system installation, and seasonal clean-up. Our team is dedicated to creating beautiful outdoor spaces that suit your needs and preferences."},{question:"What is the best time to plant a garden?",answer:"The best time to plant a garden depends on your location and the types of plants you want to grow. Generally, spring and fall are ideal for most plants, as temperatures are moderate and rainfall is more consistent. However, some plants thrive in summer or winter, so it's important to research the specific requirements of your chosen plants."},{question:"How do I maintain my landscape throughout the year?",answer:"Maintaining your landscape throughout the year involves regular tasks such as mowing, watering, fertilizing, pruning, and mulching. In spring, focus on planting and fertilizing. Summer requires consistent watering and pest control. Fall is the time for cleanup and preparation for winter. Winter maintenance includes protecting plants from frost and planning for the next growing season."},{question:"What types of plants thrive in my area?",answer:"The types of plants that thrive in your area depend on your climate, soil type, and sunlight availability. Native plants are often the best choice as they are adapted to local conditions and require less maintenance. Consult with a local nursery or landscape professional to determine the best plants for your specific location and preferences."}],image:{src:"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?q=80&w=1000&auto=format&fit=crop",alt:"Beautiful garden landscape"}},versionedSchema:fl,colorTokensSchema:eY.colorTokensSchema}),yi=fH({id:"faq-card",name:"FAQ Card",description:"A FAQ section displaying questions and answers as cards in a responsive grid layout.",type:"faq",visualConfigPresets:[{}],exampleConfig:{kicker:"FAQ",heading:"Frequently asked questions",description:"We would love to hear from you",items:[{question:"What are the best plants for a low-maintenance garden?",answer:"Create a low-maintenance garden with native plants that need less water. Use perennials like lavender and sedum, which attract pollinators. Mulch retains moisture and reduces weeds, simplifying garden care."},{question:"How to choose the right low-maintenance shrubs?",answer:"Select shrubs that are drought-tolerant and disease-resistant. Options like boxwood and juniper require minimal pruning and can thrive in various soil types."},{question:"What ground cover is best for a low-maintenance yard?",answer:"Consider creeping thyme or clover as ground cover. They spread easily, suppress weeds, and require little watering once established, making them perfect for low-maintenance landscaping."},{question:"Tips for maintaining a low-maintenance lawn?",answer:"Opt for drought-resistant grass varieties like fescue or Bermuda. Mow less frequently and leave grass clippings on the lawn to provide nutrients and reduce the need for fertilizer."},{question:"What are some easy-care flowering plants?",answer:"Plant daylilies and coneflowers for vibrant blooms with minimal effort. These perennials are hardy, withstand various conditions, and attract beneficial insects."},{question:"How to design a low-maintenance outdoor space?",answer:"Incorporate hardscaping elements like stone pathways and patios. Use raised beds for easy access and select plants that thrive in your local climate to minimize upkeep."}],bottomTitle:"Still have questions?",bottomDescription:"Send us a message, and our team will get back to you as soon as possible.",buttons:[{label:"Contact us",href:"#contact",actionType:"section"}],showButtons:!0},versionedSchema:fd,colorTokensSchema:e0.colorTokensSchema}),yn=fH({id:"faq-stretch",name:"FAQ Stretch",description:"A frequently asked questions section with a stretched layout featuring title on the left and FAQ items offset to the right.",type:"faq",visualConfigPresets:[{}],exampleConfig:{kicker:"00",heading:"/FAQ",description:"We combine strategic planning, targeted ads, and engaging content to reach ideal customers. Our focus is on clarity and relevance, ensuring our message resonates.",buttons:[{label:"Contact us",href:"#contact",actionType:"section"}],items:[{question:"How can I measure the effectiveness of my branding efforts?",answer:"Brand lift studies, social listening, website analytics, and customer surveys can help measure branding effectiveness."},{question:"How often should I update my branding materials?",answer:"Branding materials should be reviewed and updated regularly, ideally every 1-2 years, or whenever there are significant changes in your business or market."},{question:"What role does storytelling play in branding?",answer:"Storytelling helps create an emotional connection with your audience, making your brand more relatable and memorable."},{question:"What are some common branding mistakes to avoid?",answer:"Common mistakes include lacking a clear brand identity, inconsistent messaging, neglecting audience feedback, and failing to adapt to market changes."},{question:"What are the key components of a successful branding strategy?",answer:"A successful branding strategy includes defining your brand purpose, understanding your target audience, creating a unique value proposition, and consistent messaging."},{question:"How can I ensure brand consistency across different platforms?",answer:"Establish a brand style guide that outlines your brand's visual elements, tone of voice, and messaging guidelines to ensure consistency."}],showButtons:!0},versionedSchema:fp,colorTokensSchema:e2.colorTokensSchema}),yr=fH({id:"feature-bento-grid",name:"Feature Bento Grid",description:"A bento grid layout to showcase features or services with images and descriptions",type:"feature",visualConfigPresets:[],exampleConfig:{kicker:"Why choose us",heading:"Transform Your \nOutdoor Space with \nOur Expert Care",description:"We bring years of expertise, a love for nature, and a commitment to quality to every project. Whether it's a small garden or a full landscape transformation, we ensure exceptional results.",buttons:[{label:"Talk to an expert",href:"#",actionType:"section"}],items:[{type:"text",title:"Seasonal Cleanup & Landscaping",description:"Spring and fall leaf removal, debris clearing, mulching, and small landscaping enhancements such as planting or edging beds.",isInverted:!1},{type:"text",title:"Aeration & Overseeding",description:"Core aeration to improve soil oxygen and water absorption, followed by overseeding to thicken the turf and repair bare patches.",isInverted:!1},{type:"image",src:"https://images.unsplash.com/photo-1558904541-efa843a96f01?w=800",alt:"Seasonal Cleanup & Landscaping"},{type:"image",src:"https://images.unsplash.com/photo-1530836369250-ef72a3f5cda8?w=800&q=80",alt:"Seasonal Cleanup & Landscaping"},{type:"text",title:"Fertilization & Weed Control",description:"Scheduled nutrient applications and targeted weed treatments to promote lush, growth and prevent invasive species.",isInverted:!1},{type:"text",title:"Seasonal Cleanup & Landscaping",description:"Spring and fall leaf removal, debris clearing, mulching, and small landscaping enhancements such as planting or edging beds.",isInverted:!0},{type:"text",title:"Aeration & Overseeding",description:"Core aeration to improve soil oxygen and water absorption, followed by overseeding to thicken the turf and repair bare patches.",isInverted:!1},{type:"text",title:"Seasonal Cleanup & Landscaping",description:"Spring and fall leaf removal, debris clearing, mulching, and small landscaping enhancements such as planting or edging beds.",isInverted:!1},{type:"image",src:"https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=800&q=80",alt:"Seasonal Cleanup & Landscaping"}],showButtons:!0},versionedSchema:fm,colorTokensSchema:tt.colorTokensSchema}),ys=fH({id:"feature-card-carousel",name:"Feature Card Carousel",description:"A horizontally scrollable carousel of service/feature cards with icons, titles, and descriptions. Supports light and dark (inverted) modes with arrow navigation on desktop and dot paginati