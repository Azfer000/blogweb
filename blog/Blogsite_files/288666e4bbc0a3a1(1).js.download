c:!0},accent:{colorSet:et("#212121"),isThemeColor:!0},neutral:{colorSet:et("#D1D1D1",{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"accent",scale:"solid"},foregroundColor:{tint:"white",contrast:7}},secondary:{backgroundColor:{category:"secondary",scale:"interactive-bg-2"},foregroundColor:{tint:"neutral",contrast:7}}}}},globalColorOverrides:{background:{base:{category:"secondary",scale:"canvas-bg"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),"tranquil-rest":D({id:"tranquil-rest",name:"Tranquil Rest",category:"light",description:"A refined, calm color palette featuring warm cream-beige primary tones paired with deep charcoal secondary accents. The primary scale delivers low-to-moderate saturation with very high brightness, creating soft, peaceful backgrounds that evoke rest and mindfulness. The secondary provides rich, dark contrast through near-black tones that ground the palette. A saturated deep blue accent adds focused pops of color. High brightness-to-darkness contrast creates clear visual hierarchy while maintaining a serene, contemplative mood. Ideal for wellness brands, creative studios, mindfulness spaces, and artisan businesses seeking a calm, sophisticated, sleep-and-rest-inspired aesthetic.",colorPalette:{primary:{colorSet:et("#FEF3D4"),isDynamic:!0},secondary:{colorSet:et("#191919"),isDynamic:!0},accent:{colorSet:et("#15118B"),isThemeColor:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.gray,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"primary",scale:"interactive-bg-2"}},secondary:{backgroundColor:{category:"accent",scale:"interactive-bg-3"}}}}},globalColorOverrides:{background:{base:{category:"primary",scale:"canvas-bg-2"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),"dusty-rose":D({id:"dusty-rose",name:"Dusty Rose",category:"muted",description:"A refined, warm color palette featuring desaturated dusty-rose primary tones paired with muted sage-green secondary accents. The primary scale delivers low-to-moderate saturation with medium brightness, producing a gentle, romantic warmth without veering into vibrant pinks. The secondary offers cool, desaturated green tones that ground the palette with an organic contrast. High brightness backgrounds with soft, muted solid tones create an understated elegance. Ideal for florists, boutique bakeries, handmade cosmetics, artisan candle makers, and craft studios seeking a soft, feminine yet sophisticated handcrafted aesthetic.",colorPalette:{primary:{colorSet:et("#f8edf0"),isDynamic:!0},secondary:{colorSet:et("#3a693a"),isThemeColor:!0},accent:{colorSet:et("#61378b"),isDynamic:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.gray,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"secondary",scale:"solid"}},secondary:{backgroundColor:{category:"primary",scale:"interactive-bg-3"}}}}},globalColorOverrides:{background:{base:{category:"primary",scale:"interactive-bg"},featured:{category:"secondary",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),"modern-grid":D({id:"modern-grid",name:"Modern Grid",category:"modern",description:"A dark modern palette with steel-blue structure, deep cool-gray surfaces, and a clean turquoise accent for product-forward interfaces.",colorPalette:{primary:{colorSet:et("#2C3540"),isDynamic:!0},secondary:{colorSet:et("#1A232D"),isDynamic:!0},accent:{colorSet:et("#2FA39A"),isThemeColor:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.gray,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"accent",scale:"foreground-subtle"}},secondary:{backgroundColor:{category:"secondary",scale:"canvas-bg"}}}}},globalColorOverrides:{background:{base:{category:"secondary",scale:"foreground"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),"vibrant-market":D({id:"vibrant-market",name:"Vibrant Market",category:"playful",description:"A bold, highly saturated color palette featuring deep indigo-navy primary tones paired with vivid hot pink secondary accents. The primary scale provides moderate saturation at low-medium brightness, creating a rich, dramatic dark base. The secondary offers high-saturation warm pink tones that create maximum visual energy and contrast against the cool primary. A warm golden-orange accent adds further vibrancy. This is the most chromatic and energetic scheme in the collection. Ideal for artisan markets, craft fairs, creative collectives, mixed-media artists, and vibrant street-food vendors seeking a bold, festival-inspired, maximalist aesthetic.",colorPalette:{primary:{colorSet:et("#1f203a"),isDynamic:!0},secondary:{colorSet:et("#e77493"),isThemeColor:!0},accent:{colorSet:et("#f8da16"),isDynamic:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.gray,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"secondar