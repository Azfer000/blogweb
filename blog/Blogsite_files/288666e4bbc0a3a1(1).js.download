des:{button:{"flat-button":{primary:{backgroundColor:{category:"primary",scale:"canvas-bg",isInverted:!0},foregroundColor:{category:"white",scale:"solid"}},secondary:{backgroundColor:{category:"primary",scale:"canvas-bg",isInverted:!0},foregroundColor:{category:"white",scale:"solid"}}}}}}),D({id:"strategic-growth",name:"Strategic Growth",category:"preferred",description:"A sophisticated, strategic color palette featuring deep purple primary tones paired with electric teal secondary accents. The primary scale offers rich, confident colors that convey expertise and creativity. The secondary provides energetic accent colors that suggest innovation and forward momentum. Balanced saturation creates a polished, premium feel. Perfect for marketing consultancies, brand agencies, and strategic growth partners seeking to project both creativity and business acumen.",colorPalette:{primary:{colorSet:et("#7C3AED"),isThemeColor:!0},secondary:{colorSet:et("#14B8A6"),isDynamic:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.slate,{neutral:!0})}},globalColorOverrides:{background:{base:{category:"black",scale:"solid"}}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"neutral",scale:"interactive-bg"},foregroundColor:{category:"black",scale:"solid"}},secondary:{backgroundColor:{category:"primary",scale:"interactive-bg"},foregroundColor:{tint:"secondary",contrast:7}}}}}})]),typographyStyles:["space-grotesk","modern","bricolage-grotesque","syne-geist","unbounded-geist","oswald-source","albert-sans","work-sans-rubik","lexend","figtree","nunito","elegant-serif","playfair-source","libre-baskerville","fraunces-open-sans","crimson-pro","montagu-slab"],iconStyles:["material","vinyl"],defaultTypographyStyleId:"elegant-serif",defaultIconStyleId:"material",themeVisualConfig:{cornerStyle:{type:"rounded",size:"none"}},themableComponentOverrides:{button:{variant:"flat-button"}}},ek=_(ej),eA={"header-marketer":ek({sectionType:"header",sectionId:"header-marketer",content:{navItems:[{type:"link",link:{label:"Home",actionType:"page",href:"/"}},{type:"dropdown",label:"Services",navItems:[{label:"Brand Strategy",actionType:"page",href:"/services/brand-strategy"},{label:"Performance Marketing",actionType:"page",href:"/services/performance-marketing"}]},{type:"link",link:{label:"Work",actionType:"page",href:"/work"}},{type:"link",link:{label:"About",actionType:"page",href:"/about"}},{type:"link",link:{label:"Insights",actionType:"page",href:"/insights"}}],logo:{type:"text",text:"Signal & Field"},buttons:[{label:"Let's Talk",href:"/contact",actionType:"page"}]},visualConfig:{navAlignment:"center",showButtons:!0}}),"banner-double-image-bottom":ek({sectionType:"banner",sectionId:"banner-double-image-bottom",content:{kicker:"Marketing That Moves the Needle",heading:"Cut Through the Noise.\nConnect With Your Audience.",description:"Strategy, creative, and performance marketing that drives awareness, engagement, and measurable growth—without the fluff.",buttons:[{label:"Start a Project",href:"#contact",actionType:"section"}],image1:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770097729437-w58whj.png?w=800",alt:"Marketing team collaboration"},image2:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770101861243-nail25.png?w=1920",alt:"Marketing team collaborating on creative strategy"}},visualConfig:{}}),"feature-images-carousel":ek({sectionType:"feature",sectionId:"feature-images-carousel",content:{heading:"Full-Funnel Marketing\nThat Delivers Results",description:"We combine strategy, creative, and performance marketing to build systems that drive real business growth.",items:[{title:"Brand Strategy",description:"Define your positioning, messaging, and visual identity. We build foundations that make every marketing dollar work harder.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770102083635-kfc2xb.jpeg?w=800",alt:"Team brainstorming brand strategy on whiteboard"}},{title:"Content & Creative",description:"Compelling content that captures attention and drives action. From campaigns to social, we create work that resonates.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770102336078-nz22sy.png?w=800",alt:"Creative team reviewing design concepts"}},{title:"Performance Marketing",description:"Data-driven paid media that maximizes ROI. We optimize across channels to find and convert your ideal customers.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770104521997-e0yimh.png?w=800",alt:"Analytics dashboard showing marketing performance"}},{title:"Growth Systems",description:"Marketing automation and CRM integration that nurtures leads and scales your pipeline without scaling your team.",image:{src:"https://7dpcwymodrhdn90i.public.blob.vercel-storage.com/kyle/1770108397198-rfq0sy.png?w=800",alt:"Marketing automation workflow on screen"}}]},visualConfig:{}}),"metrics-numbers":ek({sectionType:"metrics",sectionId:"metrics-numbers",content:{kicker:"Proven Results",heading:"Numbers That Speak\nLouder Than Promises",description:"We measure success by the growth we generate for our clients. Here's what our partnerships have delivered.",items:[{metric:"340%",label:"Average ROI"},{metric:"2.5M+",label:"Leads Generated"},{metric:"89%",label:"Client Retention"},{metric:"50+",label:"Brands Launched"}]},visualConfig:{}}),"faq-stretch":ek({sectionType:"faq",sectionId:"faq-stretch",content:{kicker:"Common Questions",heading:"Frequently Asked Questions",description:"Got more questions? We're always happy to chat.",buttons:[{label:"Get in Touch",href:"/contact",actionType:"page"}],items:[{question:"What makes Signal & Field different from other marketing agencies?",answer:"We don't do one-size-fits-all tactics. Every engagement starts with understanding your business, audience, and goals. We build custom strategies that combine brand, content, and performance marketing into a cohesive system—not disconnected campaigns that compete with each other."},{question:"What types of businesses do you work with?",answer:"We work best with B2B companies, SaaS businesses, and professional services firms that are ready to invest in growth. Our sweet spot is companies doing $2M-$50M in revenue that need strategic marketing leadership, not just tactical execution."},{question:"How long does it take to see results?",answer:"It depends on your starting point and goals. Brand work typically shows impact over 6-12 months. Performance marketing can generate leads within weeks. We set realistic expectations upfront and provide transparent reporting so you always know what's working."},{question:"Do you offer retainer or project-based work?",answer:"Both. We offer monthly retainers for ongoing marketing partnership, as well as project-based work for specific initiatives like brand development, campaign launches, or website redesigns. Most clients start with a project and move to retainer."},{question:"How do you measure and report on results?",answer:"Every engagement includes a custom dashboard with the metrics that matter to your business. We report monthly with clear analysis of what's working, what's not, and what we're doing about it. No vanity metrics—just actionable insights."}]},visualConfig:{}}),"showcase-grid":ek({sectionType:"showcase",sectionId:"showcase-grid",content:{kicker:"Our Clients",heading:"Trusted by Growing Brands",description:"We've helped these companies cut through the noise and connect with their audiences.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-1.svg",alt:"Logo 1"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-2.svg",alt:"Logo 2"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-3.svg",alt:"Logo 3"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-4.svg",alt:"Logo 4"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-5.svg",alt:"Logo 5"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-6.svg",alt:"Logo 6"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-7.svg",alt:"Logo 7"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-8.svg",alt:"Logo 8"}]},visualConfig:{contentAlignment:"split",itemSize:"sm"}}),"text-basic":ek({sectionType:"text",sectionId:"text-basic",content:{kicker:"Our Philosophy",heading:"Marketing should make sense.",description:"Too many businesses are drowning in tactics without a strategy. We believe in building marketing systems that connect every touchpoint into a cohesive journey—from first impression to lasting customer relationship."},visualConfig:{alignment:"split"}}),"gallery-grid":ek({sectionType:"gallery",sectionId:"gallery-grid",content:{kicker:"Our Work",heading:"Campaigns that\ndeliver results.",description:"A glimpse into the strategic creative work we've produced for our clients.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770105021774-5gutwg.jpeg?w=800",alt:"Marketing strategy session"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770104979540-v4nvic.png?w=800",alt:"Brand workshop"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770107906966-8hdcrc.jpeg?w=800",alt:"Creative team collaboration"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770108380401-sbe1xb.jpeg?w=800",alt:"Analytics review"}]},visualConfig:{}}),"team-grid":ek({sectionType:"team",sectionId:"team-grid",content:{kicker:"Meet The Team",heading:"Strategists, creatives,\nand growth hackers.",description:"Our team combines decades of experience across brand strategy, performance marketing, and creative execution.",items:[{name:"Marcus Williams",role:"Founder & Chief Strategy Officer",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770097188737-x41m7v.png?w=400&h=400&fit=crop",alt:"Marcus Williams"},description:"Former VP of Marketing at two successful startups. Marcus founded Signal & Field to help growing companies build marketing that actually works."},{name:"Darius Jackson",role:"Creative Director",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770097190744-oefh51.png?w=400&h=400&fit=crop",alt:"Darius Jackson"},description:"Award-winning creative with experience at top agencies. Darius leads our brand and content teams with a focus on work that stands out."},{name:"Priya Sharma",role:"Head of Performance",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770097075142-jle3mh.png?w=400&h=400&fit=crop",alt:"Priya Sharma"},description:"Data-driven marketer who's managed over $50M in ad spend. Priya ensures every campaign delivers measurable ROI."},{name:"Jasmine Carter",role:"Content Strategist",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770097070573-01drl3.png?w=400&h=400&fit=crop",alt:"Jasmine Carter"},description:"Former journalist turned content strategist. Jasmine crafts narratives that connect brands with their audiences in meaningful ways."},{name:"Ryan Mitchell",role:"Senior Account Manager",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770097182011-56en5p.png?w=400&h=400&fit=crop",alt:"Ryan Mitchell"},description:"Client relationship expert with a background in B2B sales. Ryan ensures every partnership runs smoothly from kickoff to results."},{name:"Nadia Mansour",role:"Brand Designer",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770097072236-bu8x6y.png?w=400&h=400&fit=crop",alt:"Nadia Mansour"},description:"Visual storyteller with an eye for detail. Nadia transforms brand strategies into compelling visual identities that stand the test of time."},{name:"Jordan Ellis",role:"SEO & Analytics Lead",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770097210091-cm1hlp.png?w=400&h=400&fit=crop",alt:"Jordan Ellis"},description:"Search and analytics specialist who turns data into insights. Jordan optimizes every touchpoint for maximum organic visibility."},{name:"Sophie Laurent",role:"Social Media Manager",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770097064029-8yelhq.png?w=400&h=400&fit=crop",alt:"Sophie Laurent"},description:"Community builder and social media expert. Sophie creates engaging campaigns that spark conversations and build loyal followings."}]},visualConfig:{showImages:!0}}),"testimonial-grid":ek({sectionType:"testimonial",sectionId:"testimonial-grid",content:{kicker:"Client Success",heading:"What our\nclients say.",buttons:[{label:"Read Case Studies",href:"/work",actionType:"page"}],items:[{quote:"Signal & Field completely transformed our marketing. Within six months, our lead quality improved dramatically and our sales team couldn't be happier. They don't just run campaigns—they build systems.",name:"Michael Chen",title:"CEO, TechVenture Labs",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770098268455-7czg2y.png?w=100&h=100&fit=crop",alt:"Michael Chen"}},{quote:"Finally, a marketing partner that speaks our language. They understood our B2B sales cycle and built a content strategy that actually supports our sales team instead of creating busy work.",name:"Sarah Mitchell",title:"CMO, CloudScale Solutions",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770108544515-h5tahl.png?w=100&h=100&fit=crop",alt:"Sarah Mitchell"}},{quote:"The rebrand Signal & Field delivered exceeded our expectations. Our positioning is clearer, our messaging resonates, and we're finally attracting the right clients. Worth every penny.",name:"David Park",title:"Founder, Horizon Advisory",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770108617439-65p6ry.png?w=100&h=100&fit=crop",alt:"David Park"}},{quote:"Working with Signal & Field was a game-changer. Their strategic approach helped us reach customers we never knew existed. Highly recommend!",name:"Emily Rodriguez",title:"VP Marketing, Nexus Tech",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770108528497-weqijo.png?w=100&h=100&fit=crop",alt:"Emily Rodriguez"}}]},visualConfig:{}}),"pricing-table-3":ek({sectionType:"pricing",sectionId:"pricing-table-3",content:{heading:"Flexible partnerships\nfor your needs.",description:"Whether you need strategic guidance or full-service execution, we have a model that fits your business.",items:[{isFeatured:!1,title:"Strategy Sprint",price:"$15K",description:"A focused engagement to define your marketing strategy and roadmap.",featuresLabel:"What's included",features:[{title:"Market & competitor analysis"},{title:"Positioning & messaging framework"},{title:"90-day action plan"},{title:"2-week engagement"}],button:{label:"Learn More",href:"/contact",actionType:"page"}},{isFeatured:!0,title:"Growth Partner",price:"$10K",period:"/month",description:"Ongoing marketing partnership with strategy and execution.",featuresLabel:"What's included",features:[{title:"Dedicated strategist"},{title:"Content & campaign execution"},{title:"Performance optimization"},{title:"Monthly reporting & analysis"},{title:"Quarterly strategy reviews"}],button:{label:"Start Partnership",href:"/contact",actionType:"page"}},{isFeatured:!1,title:"Full Service",price:"$25K",period:"/month",description:"Comprehensive marketing department as a service.",featuresLabel:"What's included",features:[{title:"Everything in Growth Partner"},{title:"Brand & creative services"},{title:"Paid media management"},{title:"Marketing automation"},{title:"Priority support"}],button:{label:"Contact Us",href:"/contact",actionType:"page"}}]},visualConfig:{}}),"cta-card":ek({sectionType:"cta",sectionId:"cta-card",content:{heading:"Ready to Accelerate Your Growth?",description:"Let's talk about your goals and build a marketing system that actually delivers. No fluff, no pressure—just a conversation about what's possible.",buttons:[{label:"Start a Conversation",href:"/contact",actionType:"page"},{label:"See Our Work",href:"/work",actionType:"page"}]},visualConfig:{textAlignment:"center"}}),"contact-form-links":ek({sectionType:"contact",sectionId:"contact-form-links",content:{kicker:"Start a Conversation",heading:"Let's talk about your growth.",description:"Tell us about your business and goals. We'll get back to you within one business day.",nameLabel:"Your Name",emailLabel:"Work Email",messageLabel:"Tell us about your marketing challenges",submitButtonLabel:"Send Message",formConfig:{contactEmail:"hello@signalandfield.com",contactPhone:"(512) 555-0199",contactAddress:"123 Marketing Way, Suite 500, Austin, TX 78701",directionsLink:"https://maps.google.com",successTitle:"Message received!",successMessage:"We'll be in touch within one business day.",successButtonLabel:"Send another message"}},visualConfig:{contentAlignment:"left"}}),"contact-form-map":ek({sectionType:"contact",sectionId:"contact-form-map",content:{kicker:"Contact us",heading:"Let's grow your pipeline",description:"Tell us about your goals and we'll get back to you quickly.",nameLabel:"Your Name",emailLabel:"Work Email",messageLabel:"Tell us about your marketing challenges",submitButtonLabel:"Send Message",formConfig:{successTitle:"Message received!",successMessage:"We'll be in touch within one business day.",successButtonLabel:"Send another message"},map:{address:"500 Innovation Drive, Austin, TX 78701"}},visualConfig:{mapPosition:"right",mapType:"roadmap",zoom:15}}),"location-map":ek({sectionType:"location",sectionId:"location-map",content:{address:"500 Innovation Drive, Austin, TX 78701"},visualConfig:{mapType:"roadmap",zoom:15}}),"location-text-and-map":ek({sectionType:"location",sectionId:"location-text-and-map",content:{kicker:"Visit us",heading:"Find us nearby \n and stop by today.",description:"Use the map to get directions and visit our location.",map:{address:"500 Innovation Drive, Austin, TX 78701"}},visualConfig:{mapPositionOptions:{mapPosition:"right"},fillViewportOptions:{fillViewport:!1},mapType:"roadmap",zoom:15}}),"footer-info-grid":ek({sectionType:"footer",sectionId:"footer-info-grid",content:{logo:{type:"text",text:"Signal & Field"},navItems:[{label:"Home",href:"/",actionType:"page"},{label:"Services",href:"/services",actionType:"page"},{label:"Work",href:"/work",actionType:"page"},{label:"About",href:"/about",actionType:"page"},{label:"Insights",href:"/insights",actionType:"page"},{label:"Contact",href:"/contact",actionType:"page"},{label:"Careers",href:"/careers",actionType:"page"},{label:"Newsletter",href:"/newsletter",actionType:"page"},{label:"Resources",href:"/resources",actionType:"page"},{label:"Partners",href:"/partners",actionType:"page"}],legalLinks:[{label:"Privacy Policy",href:"/privacy",actionType:"page"},{label:"Terms of Service",href:"/terms",actionType:"page"}],socialLinks:[{platform:"linkedin",url:"https://www.linkedin.com",label:"LinkedIn"},{platform:"twitter",url:"https://www.twitter.com",label:"Twitter"},{platform:"instagram",url:"https://www.instagram.com",label:"Instagram"}],copyright:"© 2026 Signal & Field. All rights reserved.",address:"123 Marketing Way, Suite 500, Austin, TX 78701",contact:"(512) 555-0199\nhello@signalandfield.com"},visualConfig:{showSocial:!0,showLegalLinks:!0}})},eS={colorSchemeId:ex.colorSchemes[0].id,themeColorOverride:"#F97316",typographyStyleId:"elegant-serif",content:{header:eA["header-marketer"],content:[eA["banner-double-image-bottom"],eA["feature-images-carousel"],eA["metrics-numbers"],eA["testimonial-grid"],eA["text-basic"],eA["faq-stretch"],eA["team-grid"],eA["showcase-grid"],eA["gallery-grid"],eA["pricing-table-3"],eA["contact-form-links"],eA["contact-form-map"],eA["location-text-and-map"],eA["location-map"],eA["cta-card"]],footer:eA["footer-info-grid"]}},eT=T({id:"growth-engine",name:"Growth Engine",description:"A bold, high-impact design with sharp 0px corners and striking contrast. Features dramatic color pairings—either stark black/white monochrome or vibrant dark-mode themes with electric accent colors. Strong typography, generous white space, and confident layouts convey momentum and results-driven energy. Best for marketing agencies, growth consultancies, digital agencies, startup accelerators, performance marketing firms, and creative studios seeking to project innovation, boldness, and measurable impact.",previewImage:"https://example.com/image.jpg",sections:ej,themeConfig:ex,previewSchema:eS,tags:["agency","creative","startup"],isPublished:!0,examples:eA}),eI={header:{"header-marketer":{overrides:{navAlignment:"left",showButtons:!0}}},banner:{"banner-bento-grid":{overrides:{fillViewport:!0}}},feature:{"feature-centered-carousel":{}},gallery:{"gallery-grid":{}},text:{"text-basic":{overrides:{alignment:"split"}}},showcase:{"showcase-grid":{overrides:{contentAlignment:"center",itemSize:"md"}}},metrics:{"metrics-basic":{}},testimonial:{"testimonial-grid":{}},team:{"team-grid":{overrides:{showImages:!0}}},pricing:{"pricing-table":{}},faq:{"faq-card":{}},cta:{"cta-background-image":{overrides:{textAlignment:"center"}}},contact:{"contact-form-text":{overrides:{contentAlignment:"split"}},"contact-form-map":{}},location:{"location-map":{},"location-text-and-map":{}},footer:{"footer-logo-nav":{overrides:{showLegalLinks:!0}}}},eC={colorSchemes:eo([D({id:"deep-contrast",name:"Deep Contrast",category:"preferred",description:"A bold, high-contrast color palette featuring deeply saturated primary tones paired with vibrant, chromatic secondary accents. The primary scale offers rich, saturated solid colors against near-white backgrounds, creating dramatic visual impact. The secondary provides energetic accent colors with high saturation throughout. Strong brightness contrast between light backgrounds and dark solid colors creates clear visual hierarchy. Ideal for tech-forward, creative, or statement-making applications requiring bold visual presence.",colorPalette:{primary:{colorSet:et("#FCE67F"),isThemeColor:!0},secondary:{colorSet:et("#161E22"),isDynamic:!0},accent:{colorSet:et("#F97316"),isDynamic:!0},neutral:{colorSet:l.referenceColors.neutral.gray}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"secondary",scale:"solid"},foregroundColor:{tint:"secondary",contrast:7}},secondary:{backgroundColor:{category:"primary",scale:"interactive-bg-2"}}}}},globalColorOverrides:{background:{base:{category:"secondary",scale:"canvas-bg-2",isInverted:!0},surface:{category:"primary",scale:"interactive-bg-2"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),D({id:"light-elegant",name:"Light Elegant",category:"preferred",description:"A light and airy color palette with clean white backgrounds and subtle chromatic accents. Features refined indigo and violet tones that provide elegant contrast against bright, near-white surfaces. The primary and secondary scales offer gentle chromatic touches while maintaining excellent readability. Neutral tones are crisp and minimal, creating a sophisticated, modern aesthetic. Perfect for professional, clean, and contemporary applications requiring clarity and refinement.",colorPalette:{primary:{colorSet:et("#265C73"),isDynamic:!0},secondary:{colorSet:et("#ffffff"),isDynamic:!0},accent:{colorSet:et("#7C3AED"),isThemeColor:!0},neutral:{colorSet:et("#265C73")}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"primary",scale:"solid"},foregroundColor:{tint:"white",contrast:7}},secondary:{backgroundColor:{category:"secondary",scale:"canvas-bg-2"},foregroundColor:{tint:"primary",contrast:7}}}}},globalColorOverrides:{background:{base:{category:"secondary",scale:"canvas-bg"},surface:{category:"primary",scale:"interactive-bg"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}})]),typographyStyles:["elegant-serif","modern","bricolage-grotesque","playfair-source","nunito","oswald-source","space-grotesk","unbounded-geist","albert-sans","libre-baskerville","fraunces-open-sans","work-sans-rubik","lexend","figtree","crimson-pro","syne-geist","montagu-slab"],iconStyles:["material","vinyl"],defaultTypographyStyleId:"space-grotesk",defaultIconStyleId:"material",themeVisualConfig:{cornerStyle:{type:"rounded",size:"3xl"}},themableComponentOverrides:{button:{variant:"flat-button"}}},e$=_(eI),eP={"header-marketer":e$({sectionType:"header",sectionId:"header-marketer",content:{navItems:[{type:"link",link:{label:"Home",actionType:"page",href:"/"}},{type:"dropdown",label:"Services",navItems:[{label:"Investment Management",actionType:"page",href:"/services/investment-management"},{label:"Retirement Planning",actionType:"page",href:"/services/retirement-planning"}]},{type:"link",link:{label:"About",actionType:"page",href:"/about"}},{type:"link",link:{label:"Resources",actionType:"page",href:"/resources"}},{type:"link",link:{label:"Contact",actionType:"page",href:"/contact"}}],logo:{type:"text",text:"Meridian Wealth"},buttons:[{label:"Schedule Consultation",href:"/contact",actionType:"page"}]},visualConfig:{navAlignment:"left",showButtons:!0}}),"banner-bento-grid":e$({sectionType:"banner",sectionId:"banner-bento-grid",content:{heading:"Your Financial\nFuture, Secured\nand Growing",description:"We're a trusted wealth management firm helping individuals and families build, protect, and grow their wealth through personalized financial strategies and expert guidance.",buttons:[{label:"Start Planning",href:"#services",actionType:"section"}],images:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770117594676-0d84v0.png",alt:"Financial advisor reviewing portfolio with client"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770118125521-icq6m3.png",alt:"Investment performance charts and analytics"}]},visualConfig:{fillViewport:!0}}),"feature-centered-carousel":e$({sectionType:"feature",sectionId:"feature-centered-carousel",content:{kicker:"Our Services",heading:"Comprehensive Wealth\nManagement Solutions",description:"From retirement planning to investment management, we partner with you to create a financial strategy tailored to your goals and life stage.",buttons:[{label:"Explore Services",href:"/services",actionType:"page"}],items:[{title:"Investment Management",description:"Professionally managed portfolios tailored to your risk tolerance, time horizon, and financial objectives. We monitor and adjust your investments to optimize returns.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770135972091-euk45v.png",alt:"Advisor analyzing investment portfolio"}},{title:"Retirement Planning",description:"Comprehensive retirement strategies including 401(k) optimization, IRA management, Social Security planning, and income distribution strategies.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770118300273-k55tz2.png",alt:"Couple planning their retirement"}},{title:"Tax Planning & Optimization",description:"Strategic tax planning to minimize your tax burden and maximize wealth accumulation. We coordinate with your CPA for seamless execution.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770118694360-xhbopv.png",alt:"Tax planning documents and calculations"}}]},visualConfig:{}}),"gallery-grid":e$({sectionType:"gallery",sectionId:"gallery-grid",content:{kicker:"Our Approach",heading:"A Partnership\nBuilt on Trust",description:"We believe in building lasting relationships with our clients, providing guidance through every stage of their financial journey.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770119070174-uir84l.png",alt:"Financial advisory team meeting"}]},visualConfig:{}}),"showcase-grid":e$({sectionType:"showcase",sectionId:"showcase-grid",content:{kicker:"Credentials & Affiliations",heading:"Trusted by Clients, Recognized by Industry",description:"Our team holds the highest professional certifications and maintains partnerships with leading financial institutions.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-1.svg",alt:"Logo 1"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-2.svg",alt:"Logo 2"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-3.svg",alt:"Logo 3"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-4.svg",alt:"Logo 4"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-5.svg",alt:"Logo 5"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-6.svg",alt:"Logo 6"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-7.svg",alt:"Logo 7"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-8.svg",alt:"Logo 8"}]},visualConfig:{contentAlignment:"center",itemSize:"md"}}),"testimonial-grid":e$({sectionType:"testimonial",sectionId:"testimonial-grid",content:{kicker:"Client Stories",heading:"Trusted by Families\nAcross the Country",buttons:[{label:"Read More Stories",href:"/about",actionType:"page"}],items:[{quote:"Meridian Wealth helped us navigate a complex financial situation after selling our business. Their guidance on tax optimization alone saved us over $200,000. We finally feel confident about our retirement.",name:"Robert & Linda Chen",title:"Retired Business Owners",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769739114118-q17pip.png?w=100&h=100&fit=crop",alt:"Robert & Linda Chen"}},{quote:"As a physician with a demanding schedule, I needed someone I could trust completely with my finances. The team at Meridian has been exceptional—proactive, transparent, and always available when I have questions.",name:"Dr. James Mitchell",title:"Orthopedic Surgeon",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769739412640-idq608.png?w=100&h=100&fit=crop",alt:"Dr. James Mitchell"}},{quote:"After my divorce, I was overwhelmed trying to understand my financial situation. Meridian created a clear plan that gave me peace of mind and set me on a path to financial independence.",name:"Sarah Williams",title:"Marketing Executive",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769739239194-rr6g7a.png?w=100&h=100&fit=crop",alt:"Sarah Williams"}}]},visualConfig:{}}),"text-basic":e$({sectionType:"text",sectionId:"text-basic",content:{kicker:"Our Philosophy",heading:"Your goals come first.",description:"We believe financial planning isn't just about numbers—it's about understanding your life goals, protecting what matters most, and creating a roadmap to get you there with confidence."},visualConfig:{alignment:"split"}}),"metrics-basic":e$({sectionType:"metrics",sectionId:"metrics-basic",content:{kicker:"Our Track Record",heading:"Results that\nbuild confidence.",description:"We measure our success by the financial security and peace of mind we create for our clients.",items:[{metric:"15+",title:"Certified Advisors",description:"CFP® and CFA professionals"},{metric:"25+",title:"Years of Experience",description:"Navigating markets and building wealth"},{metric:"98%",title:"Client Retention Rate",description:"Long-term relationships built on trust"},{metric:"500+",title:"Families Served",description:"Across generations of financial planning"}]},visualConfig:{}}),"team-grid":e$({sectionType:"team",sectionId:"team-grid",content:{kicker:"Our Team",heading:"Advisors who\ncare deeply.",description:"Our team of certified financial planners and investment professionals brings decades of experience and a genuine commitment to your success.",items:[{name:"Michael Thornton, CFP®",role:"Founder & Senior Wealth Advisor",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770134471346-pcf8pt.png",alt:"Michael Thornton"},description:"With 30 years in wealth management, Michael founded Meridian to provide the personalized, conflict-free advice that every family deserves."},{name:"Jennifer Park, CFA",role:"Chief Investment Officer",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770119182094-qvqu78.png?w=400&h=400&fit=crop",alt:"Jennifer Park"},description:"Former portfolio manager at a top-tier investment firm. Jennifer leads our investment strategy with a focus on risk-adjusted returns."}]},visualConfig:{showImages:!0}}),"pricing-table":e$({sectionType:"pricing",sectionId:"pricing-table",content:{kicker:"Service Tiers",heading:"Transparent fee\nstructure.",description:"We believe in clear, straightforward pricing. Our fees are based on assets under management, aligning our success with yours.",items:[{isFeatured:!1,title:"Foundation",price:"0.95%",description:"For individuals and families starting their wealth journey.",features:[{title:"Comprehensive financial plan"},{title:"Investment management"},{title:"Quarterly portfolio reviews"},{title:"Annual planning meeting"}],button:{label:"Get Started",href:"/contact",actionType:"page"}},{isFeatured:!0,badgeLabel:"Most Popular",title:"Growth",price:"0.75%",description:"For established families with complex financial needs.",features:[{title:"Everything in Foundation"},{title:"Tax optimization strategies"},{title:"Estate planning coordination"},{title:"Monthly check-ins"},{title:"Dedicated advisor access"}],button:{label:"Schedule Call",href:"/contact",actionType:"page"}},{isFeatured:!1,title:"Legacy",price:"0.50%",description:"For high-net-worth families and multi-generational wealth.",features:[{title:"Everything in Growth"},{title:"Family governance planning"},{title:"Philanthropic strategy"},{title:"Private investment access"},{title:"Concierge service"}],button:{label:"Let's Talk",href:"/contact",actionType:"page"}}]},visualConfig:{}}),"faq-card":e$({sectionType:"faq",sectionId:"faq-card",content:{kicker:"Questions",heading:"Frequently asked questions",description:"Everything you need to know about working with Meridian Wealth.",items:[{question:"What is a fiduciary, and why does it matter?",answer:"A fiduciary is legally obligated to act in your best interest at all times. Unlike many advisors who only need to recommend 'suitable' investments, we are held to the highest standard of care. This means no hidden fees, no conflicts of interest, and advice that's always focused on what's best for you."},{question:"What's the minimum investment to work with you?",answer:"Our Foundation tier is designed for clients with investable assets of $250,000 or more. However, we also offer financial planning services for those building toward this threshold. We're happy to discuss your specific situation during a complimentary consultation."},{question:"How do you get paid?",answer:"We charge a transparent fee based on assets under management, typically ranging from 0.50% to 0.95% annually depending on your service tier. We don't earn commissions on products, which means our advice is never influenced by what pays us more."},{question:"How often will we meet?",answer:"Meeting frequency depends on your service tier and personal preferences. At minimum, we conduct quarterly portfolio reviews and annual comprehensive planning meetings. Many clients appreciate monthly check-ins, especially during significant life transitions."},{question:"Can you coordinate with my accountant and attorney?",answer:"Absolutely. Comprehensive wealth management requires collaboration across your professional team. We regularly work with CPAs on tax optimization, estate attorneys on wealth transfer strategies, and insurance professionals on risk management."},{question:"Is my information secure with Meridian?",answer:"Security is paramount. We use bank-level encryption, multi-factor authentication, and work exclusively with SEC-regulated custodians. Your assets are held at independent custodians like Schwab or Fidelity, never with us directly."}],bottomTitle:"Still have questions?",bottomDescription:"Our team is here to help. Reach out anytime and we'll get back to you promptly."},visualConfig:{}}),"cta-background-image":e$({sectionType:"cta",sectionId:"cta-background-image",content:{heading:"Ready to take control of your financial future?",description:"Schedule a complimentary consultation to discuss your goals and discover how we can help you achieve them.",backgroundImage:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770136586547-s3vx7n.png",alt:"Modern office with city skyline view"},buttons:[{label:"Schedule Consultation",href:"/contact",actionType:"page"},{label:"Download Our Guide",href:"/resources",actionType:"page"}]},visualConfig:{textAlignment:"center"}}),"contact-form-text":e$({sectionType:"contact",sectionId:"contact-form-text",content:{kicker:"Get in Touch",heading:"Let's start the conversation.",description:"Tell us about your financial goals and we'll schedule a complimentary consultation within 24 hours.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"Tell us about your financial goals",submitButtonLabel:"Request Consultation",formConfig:{contactEmail:"info@meridianwealth.com",contactPhone:"+1 (555) 892-4500",contactAddress:"100 Financial Plaza, Suite 3200, New York, NY 10005",successTitle:"Thank you for reaching out!",successMessage:"A member of our team will contact you within 24 hours.",successButtonLabel:"Send another message"}},visualConfig:{contentAlignment:"split"}}),"contact-form-map":e$({sectionType:"contact",sectionId:"contact-form-map",content:{kicker:"Get in Touch",heading:"Let's plan your financial future",description:"Send us a message and we'll follow up within 24 hours.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"How can we help?",submitButtonLabel:"Send Message",formConfig:{successTitle:"Thank you for reaching out!",successMessage:"A member of our 