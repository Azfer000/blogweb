,fillViewport:!0}}),"feature-grid":er({sectionType:"feature",sectionId:"feature-grid",content:{kicker:"What We Offer",heading:"Artisan quality \nin every bite.",description:"From classic sourdough to delicate pastries, we craft everything with care using traditional methods and the finest ingredients.",buttons:[{label:"View Full Menu",href:"#menu",actionType:"section"}],items:[{title:"Fresh Baked Bread",description:"Daily-baked artisan loaves using time-honored techniques and locally sourced flour.",image:{src:"https://images.unsplash.com/photo-1509440159596-0249088772ff?w=800",alt:"Fresh baked bread"}},{title:"Pastries & Sweets",description:"Handcrafted croissants, danishes, and seasonal treats made fresh every morning.",image:{src:"https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=800&q=80",alt:"Pastries and sweets"}},{title:"Custom Cakes",description:"Celebration cakes designed and decorated for your special occasions.",image:{src:"https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=800&q=80",alt:"Custom cakes"}}]},visualConfig:{imageOptions:{showImages:!0,isCaptionInside:!1}}}),"gallery-grid":er({sectionType:"gallery",sectionId:"gallery-grid",content:{kicker:"From Our Oven",heading:"A glimpse of \nour creations.",description:"Every item is handcrafted with care. Here's a taste of what awaits you at Butter & Crumb Bakery.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/298be0bd-9b81-4b61-837d-d461ff045a7d-U4yNs5Z01EPaaGeMGNAmQN3QnQpQVZ.png",alt:"Fresh artisan bread loaves"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/59a33b7c-0abd-4894-889e-e91e5f967b84-uh46Aamo260IbL0pr2VydW1nbpAdGW.png",alt:"Croissants and pastries"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/08682e80-9b18-4289-ad3d-bfddbe004baf-6Hj8hIfecfEyAJq7wVdR5BfvtE3Uol.png",alt:"Custom celebration cake"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/51c182ec-cd5a-40d6-8848-fad7f7802429-TZQza7aqstaINoGcwocnJVJ4pxcST5.png",alt:"Baker at work"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/a102a055-5a60-4b62-962e-8ff2706b099d-ecEXCeIYtZKhETVDlzKeSN0Rn9K1wU.png",alt:"Cookie assortment"}]},visualConfig:{}}),"metrics-basic":er({sectionType:"metrics",sectionId:"metrics-basic",content:{kicker:"By The Numbers",heading:"Three decades \nof excellence.",description:"Our commitment to quality has built a legacy we're proud to share.",items:[{metric:"38",title:"Years in Business",description:"Serving our community since 1985"},{metric:"500+",title:"Daily Customers",description:"Fresh bread for hundreds every day"},{metric:"15",title:"Master Bakers",description:"Skilled artisans on our team"},{metric:"100%",title:"Natural Ingredients",description:"No artificial additives or preservatives"}]},visualConfig:{}}),"text-basic":er({sectionType:"text",sectionId:"text-basic",content:{kicker:"Our Philosophy",heading:"Bread is meant to be shared.",description:"For three generations, our family has believed that breaking bread together creates connections that last a lifetime. Every loaf we bake is made with this simple truth in mind."},visualConfig:{alignment:"center"}}),"testimonial-grid":er({sectionType:"testimonial",sectionId:"testimonial-grid",content:{kicker:"Happy Customers",heading:"What our \ncommunity says.",buttons:[{label:"Leave a Review",href:"#",actionType:"section"}],items:[{quote:"The sourdough here is life-changing. I drive 30 minutes just for their Saturday morning loaves. Worth every mile!",name:"Maria Gonzalez",title:"Weekly Regular",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/e49cf4ab-da50-4bc4-9745-6298feba507e-i5fx9Ut9rjw7iwpnpfwFZ1i4v8MHMz.png",alt:"Maria Gonzalez"}},{quote:"They made our wedding cake and it was absolutely stunning. Guests are still talking about how delicious it was!",name:"Robert & Emma Walsh",title:"Wedding Clients",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/bc7076a7-2791-4fc5-9ae4-9a694b98cf16-MOmj1NRtWvzgYPUT0mrG7Z4ARZSKP9.png",alt:"Robert Walsh"}}]},visualConfig:{}}),"team-grid":er({sectionType:"team",sectionId:"team-grid",content:{kicker:"Our Bakers",heading:"Meet the hands \nbehind the bread.",description:"Our team of passionate bakers brings decades of combined experience and a deep love for the craft.",items:[{name:"Giuseppe Romano",role:"Head Baker & Owner",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/bc7076a7-2791-4fc5-9ae4-9a694b98cf16-MOmj1NRtWvzgYPUT0mrG7Z4ARZSKP9.png",alt:"Giuseppe Romano"},description:"Third-generation baker who learned the craft from his grandmother in Naples. Founded Butter & Crumb in 1985."},{name:"Marie Dubois",role:"Pastry Chef",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/e49cf4ab-da50-4bc4-9745-6298feba507e-i5fx9Ut9rjw7iwpnpfwFZ1i4v8MHMz.png",alt:"Marie Dubois"},description:"Trained at Le Cordon Bleu Paris. Creates our award-winning croissants and seasonal fruit tarts."},{name:"Jonas Müller",role:"Bread Specialist",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/85afed51-e15c-4a18-9d95-205b3ff2961f-TUtNK4oRki5eW0RN6He79sJZCSoRv9.png",alt:"Jonas Müller"},description:"Sourdough enthusiast who maintains our 30-year-old starter. Known for his perfect crust technique."}]},visualConfig:{showImages:!0}}),"showcase-grid":er({sectionType:"showcase",sectionId:"showcase-grid",content:{kicker:"As Seen In",heading:"Featured by the best",description:"We're proud to be recognized by leading food publications and local media.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-1.svg",alt:"Logo 1"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-2.svg",alt:"Logo 2"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-3.svg",alt:"Logo 3"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-4.svg",alt:"Logo 4"}],logoTags:["restaurant","cafe"]},visualConfig:{contentAlignment:"center",itemSize:"md"}}),"pricing-table":er({sectionType:"pricing",sectionId:"pricing-table",content:{kicker:"Our Offerings",heading:"Fresh from \nthe oven.",description:"Quality ingredients and artisan craftsmanship at fair prices. Pre-order for pickup or subscribe to our weekly bread box.",items:[{isFeatured:!1,title:"Daily Loaves",price:"$8",features:[{title:"Sourdough"},{title:"Whole Wheat"},{title:"Rye"}],description:"Classic artisan bread baked fresh daily using traditional methods.",button:{label:"Order Now",href:"#",actionType:"page"}},{isFeatured:!1,badgeLabel:"Popular",title:"Pastry Box",price:"$24",features:[{title:"6 Croissants"},{title:"4 Danish"},{title:"2 Scones"}],description:"A curated selection of our finest morning pastries.",button:{label:"Order Now",href:"#",actionType:"page"}}]},visualConfig:{}}),"faq-accordion":er({sectionType:"faq",sectionId:"faq-accordion",content:{kicker:"FAQ",heading:"Frequently asked questions",description:"If you have any further questions, please contact us.",buttons:[{label:"Contact Us",href:"/contact",actionType:"page"}],items:[{question:"What are your bakery hours?",answer:"We're open Tuesday through Sunday from 7am to 3pm. We're closed on Mondays for baking preparation."},{question:"Do you take custom cake orders?",answer:"Yes! We create custom cakes for all occasions. Please contact us at least one week in advance for custom orders."},{question:"Are your products made fresh daily?",answer:"Absolutely. All our breads and pastries are baked fresh every morning using traditional artisan methods."},{question:"Do you offer gluten-free options?",answer:"We have a selection of gluten-free items available. Please ask our staff about current options."}]},visualConfig:{contentAlignment:"split"}}),"cta-basic":er({sectionType:"cta",sectionId:"cta-basic",content:{heading:"Order fresh bread for your table.",description:"Pre-order online for same-day pickup, or subscribe to our weekly bread box for doorstep delivery.",buttons:[{label:"Order Online",href:"#",actionType:"section"},{label:"Subscribe to Bread Box",href:"#",actionType:"section"}]},visualConfig:{textAlignment:"center"}}),"contact-form-text":er({sectionType:"contact",sectionId:"contact-form-text",content:{kicker:"Get in Touch",heading:"Questions or special orders?",description:"We'd love to hear from you. Send us a message and we'll respond within 24 hours.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"Your Message",submitButtonLabel:"Send Message",formConfig:{contactEmail:"hello@butterandcrumb.com",contactPhone:"+1 (555) 123-4567",contactAddress:"247 Bakery Lane, Oakville, CA 94558",successTitle:"Thank you!",successMessage:"We'll get back to you soon.",successButtonLabel:"Send another message"}},visualConfig:{contentAlignment:"split"}}),"contact-form-map":er({sectionType:"contact",sectionId:"contact-form-map",content:{kicker:"Get in Touch",heading:"Questions or special orders?",description:"We'd love to hear from you. Send us a message and we'll respond within 24 hours.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"Your Message",submitButtonLabel:"Send Message",formConfig:{successTitle:"Thank you!",successMessage:"We'll get back to you soon.",successButtonLabel:"Send another message"},map:{address:"142 Artisan Lane, Charleston, SC 29401"}},visualConfig:{mapPosition:"right",mapType:"roadmap",zoom:15}}),"location-map":er({sectionType:"location",sectionId:"location-map",content:{a