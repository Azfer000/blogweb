v"]}},eR=T({id:"midnight-aurora",name:"Midnight Aurora",description:"A premium, sophisticated design with large rounded corners (3xl radius) and high visual contrast. Offers both dramatic dark themes with vibrant accent colors and clean light themes with refined chromatic tones. Features modern sans-serif typography and structured layouts that convey authority and trust. Best for financial advisors, wealth management firms, fintech companies, investment platforms, accounting firms, insurance brokers, and premium B2B services requiring a distinctive yet trustworthy professional presence.",previewImage:"https://example.com/image.jpg",sections:eI,themeConfig:eC,previewSchema:e_,tags:["finance","technology","professional services"],isPublished:!0,examples:eP}),eN={header:{"header-basic":{overrides:{navAlignment:"left",showSocial:!1,showButtons:!0}}},banner:{"banner-text-and-image":{overrides:{imagePositionOptions:{imagePosition:"right",hasImagePadding:!0},fillViewportOptions:{fillViewport:!0,verticalAlignment:"bottom"}}}},feature:{"feature-grid":{overrides:{imageOptions:{showImages:!0,isCaptionInside:!1}}}},gallery:{"gallery-grid":{}},text:{"text-basic":{overrides:{alignment:"split"}}},showcase:{"showcase-grid":{overrides:{contentAlignment:"center",itemSize:"md"}}},metrics:{"metrics-basic":{}},testimonial:{"testimonial-carousel":{overrides:{showDotsOnDesktop:!0}}},team:{"team-grid":{overrides:{showImages:!0}}},pricing:{"pricing-table-2":{}},faq:{"faq-accordion-image":{}},cta:{"cta-card-2":{overrides:{textAlignment:"left"}}},contact:{"contact-form-text":{overrides:{contentAlignment:"split"}},"contact-form-map":{}},location:{"location-map":{},"location-text-and-map":{}},footer:{"footer-logo-nav":{overrides:{showLegalLinks:!0}}}},eD={colorSchemes:eo([D({id:"dependable-tech",name:"Dependable Tech",category:"preferred",description:"A professional, tech-forward color palette featuring moderate-saturation blue primary tones paired with clean, neutral secondary accents. The primary scale offers confident, trustworthy blue solid colors against crisp backgrounds, creating a sense of reliability and technical competence. The secondary provides cool neutral tones that support readability and professionalism. Clear brightness contrast between light backgrounds and saturated solid colors establishes modern hierarchy. Ideal for IT services, tech companies, managed service providers, and B2B technology businesses seeking to convey expertise and dependability.",colorPalette:{primary:{colorSet:et("#273936"),isThemeColor:!0},secondary:{colorSet:et("#ffffff"),isDynamic:!0},accent:{colorSet:et("#06B6D4"),isDynamic:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.slate,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"primary",scale:"canvas-bg"}},secondary:{backgroundColor:{category:"secondary",scale:"foreground-subtle",isInverted:!0},foregroundColor:{category:"secondary",scale:"foreground"}}}}},globalColorOverrides:{background:{base:{category:"primary",scale:"solid"},surface:{category:"primary",scale:"solid-2"},featured:{category:"primary",scale:"canvas-bg"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),D({id:"secure-systems",name:"Secure Systems",category:"preferred",description:"A clean, enterprise-focused color palette featuring deep indigo primary tones paired with warm gold accents. The primary scale offers professional, security-conscious colors that convey stability and protection. The secondary provides a warm accent that suggests premium quality within reliability. Balanced saturation creates a polished, corporate feel. Perfect for cybersecurity firms, enterprise IT services, and managed service providers seeking to project both technical sophistication and trustworthiness.",colorPalette:{primary:{colorSet:et("#271C2D"),isThemeColor:!0},secondary:{colorSet:et("#EDD88C"),isDynamic:!0},accent:{colorSet:et("#D4AF37"),isDynamic:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.slate,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"secondary",scale:"solid"},foregroundColor:{tint:"secondary",contrast:7}},secondary:{backgroundColor:{category:"secondary",scale:"canvas-bg"},foregroundColor:{tint:"secondary",contrast:7}}}}},globalColorOverrides:{background:{base:{category:"primary",scale:"solid"},surface:{category:"primary",scale:"interactive-bg-2",isInverted:!0},featured:{category:"primary",scale:"canvas-bg"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}})]),typographyStyles:["modern","space-grotesk","bricolage-grotesque","nunito","albert-sans","work-sans-rubik","lexend","figtree","elegant-serif","playfair-source","oswald-source","unbounded-geist","libre-baskerville","fraunces-open-sans","crimson-pro","syne-geist","montagu-slab"],iconStyles:["material","vinyl"],defaultTypographyStyleId:"syne-geist",defaultIconStyleId:"material",themeVisualConfig:{cornerStyle:{type:"rounded",size:"2xl"}},themableComponentOverrides:{button:{variant:"flat-button"}}},eO=_(eN),eL={"header-basic":eO({sectionType:"header",sectionId:"header-basic",content:{navItems:[{type:"link",link:{label:"Home",actionType:"page",href:"/"}},{type:"dropdown",label:"Services",navItems:[{label:"Managed IT",actionType:"page",href:"/services/managed-it"},{label:"Cloud Services",actionType:"page",href:"/services/cloud"}]},{type:"link",link:{label:"Solutions",actionType:"page",href:"/solutions"}},{type:"link",link:{label:"About",actionType:"page",href:"/about"}},{type:"link",link:{label:"Contact",actionType:"page",href:"/contact"}}],logo:{type:"text",text:"Northshore IT"},buttons:[{label:"Free Consultation",href:"/contact",actionType:"page"}],socialLinks:[{platform:"linkedin",url:"https://www.linkedin.com",label:"LinkedIn"},{platform:"twitter",url:"https://www.twitter.com",label:"Twitter"},{platform:"facebook",url:"https://www.facebook.com",label:"Facebook"}]},visualConfig:{navAlignment:"left",showSocial:!1,showButtons:!0}}),"banner-text-and-image":eO({sectionType:"banner",sectionId:"banner-text-and-image",content:{kicker:"Reliable IT Support",heading:"Technology that works,\nso your team can too.",description:"Dependable, plain-English IT support for small and mid-sized businesses. We keep your systems secure, fast, and running smoothly.",buttons:[{label:"Get Started",href:"#contact",actionType:"section"},{label:"Our Services",href:"/services",actionType:"page"}],image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770114702113-uqqzvh.png",alt:"IT team discussing infrastructure solutions and security strategies"}},visualConfig:{imagePositionOptions:{imagePosition:"right",hasImagePadding:!0},fillViewportOptions:{fillViewport:!0,verticalAlignment:"bottom"}}}),"showcase-grid":eO({sectionType:"showcase",sectionId:"showcase-grid",content:{kicker:"Trusted By",heading:"Businesses That Count on Us",description:"From law firms to manufacturing companies, we provide reliable IT support to organizations across industries.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-1.svg",alt:"Logo 1"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-2.svg",alt:"Logo 2"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-3.svg",alt:"Logo 3"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-4.svg",alt:"Logo 4"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-5.svg",alt:"Logo 5"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-6.svg",alt:"Logo 6"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-7.svg",alt:"Logo 7"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-8.svg",alt:"Logo 8"}]},visualConfig:{contentAlignment:"center",itemSize:"md"}}),"feature-grid":eO({sectionType:"feature",sectionId:"feature-grid",content:{kicker:"Our Services",heading:"Complete IT Solutions\nfor Your Business",description:"From day-to-day troubleshooting to long-term infrastructure planning, we handle all aspects of your technology needs.",buttons:[],items:[{title:"Help Desk Support",description:"Fast, friendly technical support for your team. We resolve issues quickly so your employees can get back to work without frustration.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770115130599-zbxvm2.png",alt:"System logs and server status monitoring on laptop"}},{title:"Network Security",description:"Protect your business from cyber threats with enterprise-grade security solutions. Firewalls, monitoring, and proactive threat detection.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/918e1a2b-a886-41c7-aa82-607f6a73a9a6-GjOaswsHvSe7SZvi1YCt1EUPvwqOSK.png",alt:"System security protocol update in progress"}},{title:"Cloud Services",description:"Seamlessly migrate to the cloud or optimize your existing setup. Microsoft 365, Azure, AWS—we make cloud computing simple.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/0bfe6c6c-f8a2-4444-9adb-92da38e2fc1b-za4WfXyMPYidb2YZnyxJbyUhEfWRIb.png",alt:"High-speed fiber optic network infrastructure"}},{title:"Managed IT Services",description:"Proactive monitoring and maintenance that prevents problems before they happen. Predictable monthly costs with unlimited support.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/4c4aa98f-7fa8-49a9-be87-166a9da6ac0c-hJRjl0Fh2wfmSWXnpTFTL3CF4p0Cxj.png",alt:"Server hardware maintenance and installation"}}]},visualConfig:{imageOptions:{showImages:!0,isCaptionInside:!1}}}),"testimonial-carousel":eO({sectionType:"testimonial",sectionId:"testimonial-carousel",content:{kicker:"Client Success Stories",heading:"What Our\nClients Say",buttons:[{label:"Read More Reviews",href:"/testimonials",actionType:"page"}],items:[{quote:"Northshore IT transformed our office. We went from constant tech headaches to a system that just works. Their response time is incredible—usually within minutes, not hours.",name:"Patricia Morgan",title:"Office Manager, Sterling Law Group",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769721325726-2zot05.png?w=100&h=100&fit=crop",alt:"Patricia Morgan"}},{quote:"As a manufacturing company, downtime costs us real money. Northshore set up monitoring and backup systems that have prevented multiple potential disasters. Worth every penny.",name:"Robert Chen",title:"Operations Director, PrecisionParts Inc.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769737578167-9u616f.png?w=100&h=100&fit=crop",alt:"Robert Chen"}},{quote:"Finally, an IT company that speaks plain English! They explain things in ways our whole team understands and never make us feel stupid for asking questions.",name:"Jennifer Walsh",title:"CEO, Bright Horizons Consulting",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769725163227-kvltr1.png?w=100&h=100&fit=crop",alt:"Jennifer Walsh"}},{quote:"We were hacked three years ago—it was devastating. Northshore rebuilt our security from the ground up. We sleep better knowing they're monitoring our systems 24/7.",name:"Marcus Thompson",title:"Managing Partner, Thompson Financial",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769725236492-gf5hw7.png?w=100&h=100&fit=crop",alt:"Marcus Thompson"}},{quote:"The transition to Microsoft 365 was seamless. Northshore handled everything and trained our staff. Productivity has improved across the board since the switch.",name:"Amanda Rodriguez",title:"HR Director, Greenfield Properties",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769721319953-oqgv9d.png?w=100&h=100&fit=crop",alt:"Amanda Rodriguez"}}]},visualConfig:{showDotsOnDesktop:!0}}),"team-grid":eO({sectionType:"team",sectionId:"team-grid",content:{kicker:"Meet Our Team",heading:"The People Behind Your IT",description:"Our certified engineers bring decades of combined experience and a genuine commitment to keeping your business running smoothly.",buttons:[{label:"Learn More About Us",href:"/about",actionType:"page"}],items:[{name:"David Northfield",role:"Founder & Chief Technology Officer",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/74088a84-5152-465b-8be9-ac982e673b75-UnwWEv20qfsoqvuB0RBTsPXLwe9iPa.png",alt:"David Northfield"},description:"With 20+ years in IT infrastructure and a passion for helping businesses succeed, David founded Northshore IT to provide the kind of reliable, plain-English support he wished existed when he was starting out."},{name:"Sarah Kimura",role:"Director of Client Services",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/8c54336b-1e76-40da-a621-a9e6918d4c2d-kipEea91HD1OZaG6RoTfz6yVP6OyKF.png",alt:"Sarah Kimura"},description:"Sarah leads our client success team with a focus on proactive communication and long-term relationships. She ensures every client gets personalized attention and solutions that fit their unique needs."}]},visualConfig:{showImages:!0}}),"text-basic":eO({sectionType:"text",sectionId:"text-basic",content:{kicker:"Our Philosophy",heading:"Technology should just work.",description:"We believe IT shouldn't be complicated or scary. Our job is to make technology disappear into the background—reliable, secure, and always there when you need it—so you can focus on what you do best."},visualConfig:{alignment:"split"}}),"gallery-grid":eO({sectionType:"gallery",sectionId:"gallery-grid",content:{kicker:"Our Facilities",heading:"Enterprise-grade\ninfrastructure.",description:"A look at our state-of-the-art operations center and the technology that keeps your business running.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/d4b13f14-c556-4acf-a04e-a34db5e79ddd-aBkr6Fo82oeWVJlDPYiKiorBUEWTub.png",alt:"IT professional in enterprise server room"}]},visualConfig:{}}),"metrics-basic":eO({sectionType:"metrics",sectionId:"metrics-basic",content:{kicker:"By The Numbers",heading:"Reliability you\ncan count on.",description:"Our track record speaks for itself.",items:[{metric:"99.9%",title:"Uptime Guarantee",description:"Industry-leading reliability for our managed clients"},{metric:"15 min",title:"Average Response",description:"Fast support when you need it most"},{metric:"500+",title:"Businesses Served",description:"From small offices to mid-size enterprises"},{metric:"24/7",title:"Monitoring",description:"Around-the-clock protection for your systems"}]},visualConfig:{}}),"pricing-table-2":eO({sectionType:"pricing",sectionId:"pricing-table-2",content:{heading:"Predictable IT costs,\nno surprises.",description:"Choose the level of support that's right for your business. All plans include 24/7 monitoring and help desk access.",items:[{isFeatured:!1,title:"Essentials",price:"$99",description:"Core IT support for small businesses.",features:[{title:"Help desk support"},{title:"Remote troubleshooting"},{title:"Basic monitoring"},{title:"Security updates"}],button:{label:"Get Started",href:"/contact",actionType:"page"}},{isFeatured:!0,title:"Professional",price:"$149",description:"Complete IT management for growing teams.",features:[{title:"Everything in Essentials"},{title:"24/7 monitoring"},{title:"Cloud backup"},{title:"Cybersecurity suite"},{title:"Quarterly reviews"}],button:{label:"Start Free Trial",href:"/contact",actionType:"page"}},{isFeatured:!1,title:"Enterprise",price:"Custom",description:"Tailored solutions for complex environments.",features:[{title:"Everything in Professional"},{title:"Dedicated account manager"},{title:"Custom SLAs"},{title:"On-site support"},{title:"Strategic planning"}],button:{label:"Contact Us",href:"/contact",actionType:"page"}}]},visualConfig:{}}),"faq-accordion-image":eO({sectionType:"faq",sectionId:"faq-accordion-image",content:{heading:"Common questions",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/a055c8d5-12c0-4d84-a3aa-cd08d9d62b0e-IAfWY8tpPc9M9fjTOkQlYShAZsYSIu.png",alt:"IT professionals collaborating on technical solutions"},items:[{question:"How quickly can you respond to issues?",answer:"Our average response time is under 15 minutes during business hours. For critical issues, we have 24/7 emergency support with guaranteed response times based on your service level."},{question:"Do we need to switch everything at once?",answer:"Not at all. We can transition your systems gradually to minimize disruption. Many clients start with help desk support and expand to full managed services over time."},{question:"What about our existing software and systems?",answer:"We work with your existing technology investments. Our team is certified in all major platforms including Microsoft 365, Google Workspace, and most business applications."},{question:"How do you handle cybersecurity?",answer:"Security is built into everything we do. Our managed plans include enterprise-grade antivirus, email filtering, firewall management, and regular security assessments."},{question:"Can you help with compliance requirements?",answer:"Yes. We have experience helping businesses meet HIPAA, PCI-DSS, SOC 2, and other compliance requirements. We'll work with you to implement appropriate controls and documentation."}]},visualConfig:{}}),"cta-card-2":eO({sectionType:"cta",sectionId:"cta-card-2",content:{heading:"Ready to Simplify Your IT?",description:"Let's discuss how we can take technology off your plate so you can focus on running your business. Free consultation, no pressure.",buttons:[{label:"Schedule Free Consultation",href:"/contact",actionType:"page"}]},visualConfig:{textAlignment:"left"}}),"contact-form-text":eO({sectionType:"contact",sectionId:"contact-form-text",content:{kicker:"Get in Touch",heading:"Let's talk about your IT needs.",description:"Schedule a free consultation or reach out with any questions. We typically respond within a few hours.",nameLabel:"Your Name",emailLabel:"Work Email",messageLabel:"How can we help?",submitButtonLabel:"Send Message",formConfig:{contactEmail:"support@northshoreit.com",contactPhone:"(555) 234-5678",contactAddress:"789 Technology Drive, Suite 400, Boston, MA 02110",successTitle:"Message received!",successMessage:"We'll be in touch shortly.",successButtonLabel:"Send another message"}},visualConfig:{contentAlignment:"split"}}),"contact-form-map":eO({sectionType:"contact",sectionId:"contact-form-map",content:{kicker:"Contact us",heading:"Let's talk about your IT goals",description:"Reach out and our team will respond shortly.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"How can we help?",submitButtonLabel:"Send Message",formConfig:{successTitle:"Message received!",successMessage:"We'll be in touch shortly.",successButtonLabel:"Send another message"},map:{address:"200 Congress Avenue, Austin, TX 78701"}},visualConfig:{mapPosition:"right",mapType:"roadmap",zoom:15}}),"location-map":eO({sectionType:"location",sectionId:"location-map",content:{address:"200 Congress Avenue, Austin, TX 78701"},visualConfig:{mapType:"roadmap",zoom:15}}),"location-text-and-map":eO({sectionType:"location",sectionId:"location-text-and-map",content:{kicker:"Visit us",heading:"Find us nearby \n and stop by today.",description:"Use the map to get directions and visit our location.",map:{address:"200 Congress Avenue, Austin, TX 78701"}},visualConfig:{mapPositionOptions:{mapPosition:"right"},mapType:"roadmap",zoom:15,fillViewportOptions:{fillViewport:!1}}}),"footer-logo-nav":eO({sectionType:"footer",sectionId:"footer-logo-nav",content:{logo:{type:"text",text:"Northshore IT"},navItems:[{label:"Home",href:"/",actionType:"page"},{label:"Services",href:"/services",actionType:"page"},{label:"Solutions",href:"/solutions",actionType:"page"},{label:"About",href:"/about",actionType:"page"},{label:"Contact",href:"/contact",actionType:"page"}],legalLinks:[{label:"Privacy Policy",href:"/privacy",actionType:"page"},{label:"Terms of Service",href:"/terms",actionType:"page"},{label:"Security Policy",href:"/security",actionType:"page"}],copyright:"© 2026 Northshore IT. All rights reserved."},visualConfig:{showLegalLinks:!0}})},eB={colorSchemeId:eD.colorSchemes[0].id,themeColorOverride:"#2563EB",typographyStyleId:"syne-geist",content:{header:eL["header-basic"],content:[eL["banner-text-and-image"],eL["showcase-grid"],eL["feature-grid"],eL["testimonial-carousel"],eL["team-grid"],eL["text-basic"],eL["gallery-grid"],eL["metrics-basic"],eL["faq-accordion-image"],eL["pricing-table-2"],eL["cta-card-2"],eL["contact-form-text"],eL["contact-form-map"],eL["location-text-and-map"],eL["location-map"]],footer:eL["footer-logo-nav"]}},eE=T({id:"reliable-core",name:"Reliable Core",description:"A clean, professional design built for trust and clarity. Features structured layouts with clear visual hierarchy, moderate rounded corners, and balanced chromatic color schemes. Sans-serif typography and organized grid sections convey technical competence and reliability. Best for IT service providers, SaaS companies, managed service providers, tech consultancies, B2B software businesses, and enterprise services where projecting expertise and dependability is essential.",previewImage:"https://example.com/image.jpg",sections:eN,themeConfig:eD,previewSchema:eB,tags:["technology","professional services","enterprise"],isPublished:!0,examples:eL}),eF={header:{"header-basic":{overrides:{navAlignment:"center",showSocial:!0,showButtons:!1}}},banner:{"banner-orbit":{overrides:{circleCount:3}}},gallery:{"gallery-grid":{}},feature:{"feature-expandable-carousel":{overrides:{textContentAlignment:"center"}}},metrics:{"metrics-basic":{}},testimonial:{"testimonial-carousel":{overrides:{showDotsOnDesktop:!0}}},team:{"team-grid":{overrides:{showImages:!0}}},text:{"text-basic":{overrides:{alignment:"split"}}},showcase:{"showcase-grid":{overrides:{contentAlignment:"center",itemSize:"md"}}},cta:{"cta-card":{overrides:{textAlignment:"center"}}},faq:{"faq-accordion-image":{}},pricing:{"pricing-table-2":{}},contact:{"contact-form-text":{overrides:{contentAlignment:"split"}},"contact-form-map":{}},location:{"location-map":{},"location-text-and-map":{}},footer:{"footer-info-grid":{overrides:{showSocial:!0,showLegalLinks:!0}}}},eM={colorSchemes:eo([D({id:"calming-nature",name:"Calming Nature",category:"preferred",description:"A serene, calming color palette featuring soft sage green primary tones paired with gentle lavender secondary accents. The primary scale offers low-saturation, high-brightness colors that evoke natural tranquility. The secondary provides subtle warmth through barely-there lavender tints. Creates a peaceful, zen-like atmosphere with minimal visual noise. Ideal for wellness centers, spas, yoga studios, and health-focused businesses seeking calm, restorative presence.",colorPalette:{primary:{colorSet:et("#F4F1F4"),isDynamic:!0},secondary:{colorSet:et("#504850"),isDynamic:!0},accent:{colorSet:et("#8B5CF6"),isThemeColor:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.sage,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"accent",scale:"solid-2"}}}}},globalColorOverrides:{background:{base:{category:"primary",scale:"interactive-bg"},surface:{category:"primary",scale:"interactive-bg-2"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),D({id:"zen-minimal",name:"Zen Minimal",category:"preferred",description:"A minimal, zen-inspired color palette using soft mint green with complementary jade accents. Both scales feature very low saturation and high brightness, creating an airy, spa-like atmosphere. The extremely subtle color differences evoke simplicity and mindfulness. Perfect for meditation apps, wellness retreats, and minimalist health brands seeking peaceful, uncluttered visual identity.",colorPalette:{primary:{colorSet:et("#D9E0E0"),isDynamic:!0},secondary:{colorSet:et("#495048"),isDynamic:!0},accent:{colorSet:et("#D03F82"),isThemeColor:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.sage,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"accent",scale:"solid-2"}}}}},globalColorOverrides:{background:{base:{category:"primary",scale:"interactive-bg"},surface:{category:"primary",scale:"canvas-bg-2"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}})]),typographyStyles:["elegant-serif","modern","bricolage-grotesque","playfair-source","nunito","oswald-source","space-grotesk","unbounded-geist","albert-sans","libre-baskerville","fraunces-open-sans","work-sans-rubik","lexend","figtree","crimson-pro","syne-geist","montagu-slab"],iconStyles:["vinyl","material"],defaultTypographyStyleId:"elegant-serif",defaultIconStyleId:"vinyl",themeVisualConfig:{cornerStyle:{type:"rounded",size:"3xl"}},themableComponentOverrides:{button:{variant:"flat-button"}}},eU=[{platform:"instagram",url:"https://www.instagram.com",label:"Instagram"},{platform:"facebook",url:"https://www.facebook.com",label:"Facebook"},{platform:"youtube",url:"https://www.youtube.com",label:"YouTube"}],eZ=_(eF),eV={"header-basic":eZ({sectionType:"header",sectionId:"header-basic",content:{navItems:[{type:"link",link:{label:"Home",actionType:"page",href:"/"}},{type:"dropdown",label:"Services",navItems:[{label:"Massage Therapy",actionType:"page",href:"/services/massage-therapy"},{label:"Guided Meditation",actionType:"page",href:"/services/guided-meditation"}]},{type:"link",link:{label:"Classes",actionType:"page",href:"/classes"}},{type:"link",link:{label:"About",actionType:"page",href:"/about"}},{type:"link",link:{label:"Contact",actionType:"page",href:"/contact"}}],logo:{type:"text",text:"Serenity"},buttons:[{label:"Book Session",href:"/book",actionType:"page"}],socialLinks:eU},visualConfig:{navAlignment:"center",showSocial:!0,showButtons:!1}}),"banner-orbit":eZ({sectionType:"banner",sectionId:"banner-orbit",content:{heading:"Wellness\nmade simple",description:"Our holistic approach guides you through transformative practices that restore balance to mind, body, and spirit.",buttons:[{label:"Begin Your Journey",actionType:"section",href:"#services"}],items:[{type:"image",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/de0e297b-3ce9-44ff-9c3f-ef46fd553373-3hCPCbrCEo1KUy50vD6tqHwRipgUVA.png",alt:"Group meditation class in peaceful studio"},aspectRatio:"portrait"},{type:"image",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/45696dcc-6e5a-42a9-a745-f12a811319a4-wHQBezqWwOOPLq3YakA5sbnd6prDJy.png",alt:"Spa foot bath with herbs and flowers"},aspectRatio:"square"},{type:"image",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/9d55068d-d4dd-454a-9291-505f061dc488-a7Hu6JnbpbEc4kUQSZVFFm9PYhjYRy.png",alt:"Serene spa pool with mountain view"},aspectRatio:"landscape"},{type:"keyword",keyword:"Balance"},{type:"keyword",keyword:"Renewal"},{type:"keyword",keyword:"Serenity"}]},visualConfig:{circleCount:3}}),"feature-expandable-carousel":eZ({sectionType:"feature",sectionId:"feature-expandable-carousel",content:{kicker:"Our Approach",heading:"Nurturing treatments for complete wellness",description:"From therapeutic massage to mindful meditation, each service is thoughtfully crafted to address your unique needs and guide you toward inner peace.",buttons:[{label:"View All Services",actionType:"page",href:"/services"},{label:"Book Consultation",actionType:"section",href:"#contact"}],items:[{tag:"01",title:"Therapeutic Massage",description:"Deep tissue, Swedish, and hot stone therapies release tension and restore circulation. Each session is customized to your body's unique needs."},{tag:"02",title:"Guided Meditation",description:"Daily sessions for all levels. From gentle breathing exercises to deep visualization practices. Find your center and cultivate lasting calm."},{tag:"03",title:"Energy Healing",description:"Reiki, sound therapy, and chakra balancing clear energetic blockages and restore your natural flow of vitality and well-being."},{tag:"04",title:"Yoga Practice",description:"From gentle restorative sessions to dynamic vinyasa flows. Expert instructors guide you through practices suited to your experience level."}]},visualConfig:{textContentAlignment:"center"}}),"gallery-grid":eZ({sectionType:"gallery",sectionId:"gallery-grid",content:{kicker:"Our Space",heading:"A haven of\ntranquility",description:"Step inside our sanctuary and leave the outside world behind. Every corner is designed for peace and restoration.",buttons:[{label:"Take a Virtual Tour",actionType:"page",href:"/tour"}],items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770144995836-dkyl0i.png",alt:"Massage therapist in treatment room"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770145217601-igdbvr.png",alt:"Serene spa pool with mountain view"}]},visualConfig:{}}),"testimonial-carousel":eZ({sectionType:"testimonial",sectionId:"testimonial-carousel",content:{kicker:"Guest Experiences",heading:"Stories of\ntransformation",description:"Join our community of wellness seekers who have found peace, balance, and renewal at Serenity.",buttons:[{label:"Read More Reviews",href:"#reviews",actionType:"section"}],items:[{quote:"After just one session, I felt like a different person. The chronic tension I'd carried for years finally released. This place is truly healing.",name:"Rebecca Moore",title:"Monthly Member",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769721319354-gmuce2.png?w=100&h=100&fit=crop",alt:"Rebecca Moore"}},{quote:"The meditation classes changed my relationship with stress. I've learned tools that help me stay centered even during my busiest days.",name:"Jonathan Lee",title:"Wellness Retreat Guest",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769737578167-9u616f.png?w=100&h=100&fit=crop",alt:"Jonathan Lee"}},{quote:"Every therapist I've seen has been exceptional. They truly listen and customize each treatment. I won't go anywhere else.",name:"Amara Okafor",title:"Regular Client",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769721319815-800y7a.png?w=100&h=100&fit=crop",alt:"Amara Okafor"}}]},visualConfig:{showDotsOnDesktop:!0}}),"text-basic":eZ({sectionType:"text",sectionId:"text-basic",content:{kicker:"Our Philosophy",heading:"Wellness is a journey, not a destination.",description:"At Serenity, we believe true wellness encompasses mind, body, and spirit. Our holistic approach combines ancient wisdom with modern techniques to help you find lasting balance and peace."},visualConfig:{alignment:"split"}}),"showcase-grid":eZ({sectionType:"showcase",sectionId:"showcase-grid",content:{kicker:"Trusted By",heading:"Featured in leading publications",description:"We're honored to be recognized by wellness and lifestyle publications.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-1.svg",alt:"Logo 1"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-2.svg",alt:"Logo 2"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-3.svg",alt:"Logo 3"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-4.svg",alt:"Logo 4"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-5.svg",alt:"Logo 5"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-6.svg",alt:"Logo 6"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-7.svg",alt:"Logo 7"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-8.svg",alt:"Logo 8"}]},visualConfig:{contentAlignment:"center",itemSize:"md"}}),"metrics-basic":eZ({sectionType:"metrics",sectionId:"metrics-basic",content:{kicker:"Our Impact",heading:"Transforming lives\nthrough wellness.",description:"Our commitment to holistic care has touched thousands of lives.",items:[{metric:"15K+",title:"Treatments Delivered",description:"Massages, energy work, and healing sessions"},{metric:"98%",title:"Client Satisfaction",description:"Based on post-session surveys"},{metric:"12",title:"Years of Service",description:"Serving our community since 2014"},{metric:"25+",title:"Certified Practitioners",description:"Experts in various healing modalities"}]},visualConfig:{}}),"team-grid":eZ({sectionType:"team",sectionId:"team-grid",content:{kicker:"Our Practitioners",heading:"Healers dedicated\nto your wellbeing.",description:"Our team of certified practitioners brings together diverse expertise in massage, meditation, yoga, and energy healing.",items:[{name:"Maya Sunrise",role:"Founder & Lead Practitioner",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769725157646-zpdjg2.png?w=400&h=400&fit=crop",alt:"Maya Sunrise"},description:"A certified yoga instructor and Reiki master with over 20 years of experience. Maya founded Serenity to create a sanctuary for holistic healing."},{name:"James Stillwater",role:"Massage Therapist",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769725244854-a01xu1.png?w=400&h=400&fit=crop",alt:"James Stillwater"},description:"Specializing in deep tissue and therapeutic massage. James combines Eastern and Western techniques for profound physical release."},{name:"David Chen",role:"Acupuncturist",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769737580823-hfvwh2.png?w=400&h=400&fit=crop",alt:"David Chen"},description:"Licensed acupuncturist with training in Traditional Chinese Medicine. David specializes in stress relief and pain management."},{name:"Aria Moon",role:"Meditation Guide",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769725163227-kvltr1.png?w=400&h=400&fit=crop",alt:"Aria Moon"},description:"Trained in Vipassana and mindfulness traditions. Aria leads our daily meditation classes and sound healing sessions."},{name:"Elena Rivers",role:"Yoga Instructor",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769721321224-2jpj42.png?w=400&h=400&fit=crop",alt:"Elena Rivers"},description:"Certified in Hatha, Vinyasa, and Restorative yoga. Elena creates accessible classes for all experience levels."},{name:"Sarah Bloom",role:"Sound Healer",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769725152412-4m4ggp.png?w=400&h=400&fit=crop",alt:"Sarah Bloom"},description:"Master of crystal singing bowls and gong meditation. Sarah's sound bath sessions create profound relaxation and inner peace."}]},visualConfig:{showImages:!0}}),"pricing-table-2":eZ({sectionType:"pricing",sectionId:"pricing-table-2",content:{heading:"Invest in your wellbeing.",description:"Choose from our curated packages or book individual sessions. Gift cards available.",items:[{isFeatured:!1,title:"Single Session",price:"$120",period:"/session",featuresLabel:"Includes:",description:"Perfect for first-time visitors or occasional self-care.",features:[{title:"60-minute treatment"},{title:"Choice of modality"},{title:"Aromatherapy included"},{title:"Herbal tea service"}],button:{label:"Book Now",href:"/book",actionType:"page"}},{isFeatured:!0,badgeLabel:"Best Value",title:"Wellness Journey",price:"$499",period:"/package",featuresLabel:"Includes:",description:"A transformative package for deep healing and renewal.",features:[{title:"5 sessions (save $101)"},{title:"Personalized plan"},{title:"Priority booking"},{title:"Wellness consultation"},{title:"Take-home aromatherapy"}],button:{label:"Begin Journey",href:"/book",actionType:"page"}}]},visualConfig:{}}),"faq-accordion-image":eZ({sectionType:"faq",sectionId:"faq-accordion-image",content:{heading:"Frequently asked questions",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770146305832-qdbk6o.png",alt:"Relaxing spa treatment room"},items:[{question:"What should I expect during my first visit?",answer:"Your first visit begins with a brief consultation where we discuss your goals and any health considerations. We'll then guide you through your chosen treatment in a peaceful, private room."},{question:"How should I prepare for a session?",answer:"We recommend arriving 10-15 minutes early to settle in. Avoid heavy meals and caffeine beforehand. Wear comfortable clothing for yoga and meditation classes."},{question:"What is your cancellation policy?",answer:"We request 24 hours notice for cancellations or rescheduling. Late cancellations may incur a 50% fee. We understand emergencies happen and will work with you when possible."},{question:"Are your treatments suitable for beginners?",answer:"Absolutely! All our services welcome beginners. Our practitioners will guide you through every step and adjust their approach to your comfort level and experience."},{question:"Do you offer gift certificates?",answer:"Yes! Gift certificates are available for any amount or specific services. They make wonderful gifts and never expire. Purchase online or in our studio."}]},visualConfig:{}}),"cta-card":eZ({sectionType:"cta",sectionId:"cta-card",content:{heading:"Begin your wellness journey today",description:"Book a consultation to discuss your goals and create your personalized path to balance, renewal, and lasting peace.",buttons:[{label:"Book Consultation",href:"/book",actionType:"page"},{label:"View Packages",href:"/packages",actionType:"page"}]},visualConfig:{textAlignment:"center"}}),"contact-form-text":eZ({sectionType:"contact",sectionId:"contact-form-text",content:{kicker:"Connect With Us",heading:"We'd love to hear from you.",description:"Have questions about our services or ready to book? Reach out and we'll respond within 24 hours.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"How can we help you find balance?",submitButtonLabel:"Send Message",formConfig:{contactEmail:"hello@serenitywellness.com",contactPhone:"(555) 456-7890",contactAddress:"123 Peaceful Lane, Harmony Valley, CA 94559",successTitle:"Message received!",successMessage:"We'll be in touch soon. Breathe deeply.",successButtonLabel:"Send another message"}},visualConfig:{contentAlignment:"split"}}),"contact-form-map":eZ({sectionType:"contact",sectionId:"contact-form-map",content:{kicker:"Connect With Us",heading:"We'd love to hear from you.",description:"Reach out any time and we'll respond within 24 hours.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"How can we help?",submitButtonLabel:"Send Message",formConfig:{successTitle:"Message received!",successMessage:"We'll be in touch soon.",successButtonLabel:"Send another message"},map:{address:"New York, NY 10001"}},visualConfig:{mapPosition:"right",mapType:"roadmap",zoom:15}}),"location-map":eZ({sectionType:"location",sectionId:"location-map",content:{address:"New York, NY 10001"},visualConfig:{mapType:"roadmap",zoom:15}}),"location-text-and-map":eZ({sectionType:"location",sectionId:"location-text-and-map",content:{kicker:"Visit us",heading:"Find us nearby \n and stop by today.",description:"Use the map to get directions and visit our location.",map:{address:"New York, NY 10001"}},visualConfig:{mapPositionOptions:{mapPosition:"right"},fillViewportOptions:{fillViewport:!1},mapType:"roadmap",zoom:15}}),"footer-info-grid":eZ({sectionType:"footer",sectionId:"footer-info-grid",content:{logo:{type:"text",text:"Serenity"},navItems:[{label:"Home",href:"/",actionType:"page"},{label:"Services",href:"/services",actionType:"page"},{label:"Classes",href:"/classes",actionType:"page"},{label:"About",href:"/about",actionType:"page"},{label:"Contact",href:"/contact",actionType:"page"},{label:"Book Now",href:"/book",actionType:"page"},{label:"Gift Cards",href:"/gift-cards",actionType:"page"},{label:"Blog",href:"/blog",actionType:"page"},{label:"Careers",href:"/careers",actionType:"page"},{label:"FAQ",href:"/faq",actionType:"page"}],legalLinks:[{label:"Privacy Policy",href:"/privacy",actionType:"page"},{label:"Terms of Service",href:"/terms",actionType:"page"},{label:"Cancellation Policy",href:"/cancellation",actionType:"page"}],socialLinks:eU,copyright:"© 2026 Serenity Wellness. Find your peace.",address:"123 Peaceful Lane, Harmony Valley, CA 94559",contact:"(555) 456-7890\nhello@serenitywellness.com"},visualConfig:{showSocial:!0,showLegalLinks:!0}})},eq={colorSchemeId:eM.colorSchemes[0].id,themeColorOverride:"#4A7C59",typographyStyleId:"elegant-serif",content:{header:eV["header-basic"],content:[eV["banner-orbit"],eV["gallery-grid"],eV["feature-expandable-carousel"],eV["metrics-basic"],eV["testimonial-carousel"],eV["team-grid"],eV["text-basic"],eV["showcase-grid"],eV["cta-card"],eV["faq-accordion-image"],eV["pricing-table-2"],eV["contact-form-text"],eV["contact-form-map"],eV["location-text-and-map"],eV["location-map"]],footer:eV["footer-info-grid"]}},eW=T({id:"serene-wellness",name:"Serene Wellness",description:"A tranquil, zen-inspired design with very rounded pill-shaped corners (3xl radius) and elegant serif typography. Features soft, low-saturation color palettes with high-brightness backgrounds that create an airy, spa-like atmosphere. Gentle gradients, generous spacing, and flowing layouts evoke calm and restoration. Best for wellness centers, yoga studios, spas, meditation apps, holistic health practitioners, massage therapists, and mental health services seeking to convey peace and rejuvenation.",previewImage:"https://example.com/image.jpg",sections:eF,themeConfig:eM,previewSchema:eq,tags:["healthcare","hospitality","personal"],isPublished:!0,examples:eV}),eG={header:{"header-basic":{overrides:{navAlignment:"left",showSocial:!1,showButtons:!0}}},banner:{"banner-card-and-background-image":{overrides:{fullscreenOptions:{fillViewport:!0,verticalAlignment:"bottom"}}}},feature:{"feature-carousel-accordion":{}},gallery:{"gallery-grid":{}},text:{"text-basic":{overrides:{alignment:"split"}}},showcase:{"showcase-grid":{overrides:{contentAlignment:"center",itemSize:"md"}}},metrics:{"metrics-basic":{}},testimonial:{"testimonial-carousel":{overrides:{showDotsOnDesktop:!0}}},team:{"team-grid":{overrides:{showImages:!0}}},pricing:{"pricing-table":{}},faq:{"faq-accordion":{overrides:{contentAlignment:"split"}}},cta:{"cta-basic":{overrides:{textAlignment:"split"}}},contact:{"contact-form-text":{overrides:{contentAlignment:"split"}},"contact-form-map":{}},location:{"location-map":{},"location-text-and-map":{}},footer:{"footer-info-grid":{overrides:{showSocial:!0,showLegalLinks:!0}}}},eH={colorSchemes:eo([D({id:"steady-growth",name:"Steady Growth",category:"preferred",description:"A trustworthy, professional color palette featuring moderate-saturation navy primary tones paired with warm, approachable gold secondary accents. The primary scale offers balanced saturation solid colors against clean backgrounds, creating a sense of stability and reliability. The secondary provides warm accent colors that convey optimism and forward momentum. Clear brightness contrast between light backgrounds and deep solid colors establishes professional hierarchy. Ideal for financial services, coaching, consulting, and professional service businesses seeking to convey trust and competence.",colorPalette:{primary:{colorSet:et("#ECEFF0")},secondary:{colorSet:et("#334F58"),isDynamic:!0},accent:{colorSet:et("#D4A017"),isThemeColor:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.slate,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"accent",scale:"solid"},foregroundColor:{tint:"neutral",contrast:7}},secondary:{backgroundColor:{category:"primary",scale:"canvas-bg"}}}}},globalColorOverrides:{background:{base:{category:"primary",scale:"interactive-bg"},surface:{category:"primary",scale:"interactive-bg-3"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),D({id:"clean-confidence",name:"Clean Confidence",category:"preferred",description:"A clean, minimalist color palette featuring soft teal primary tones paired with light, airy backgrounds. Both scales offer low-to-moderate saturation with high brightness, creating a fresh and approachable atmosphere. The subtle color differences evoke clarity and simplicity, reflecting a judgment-free, accessible approach to financial guidance. Perfect for financial coaches, advisors, and wellness-focused financial services seeking to reduce client stress and build trust through visual calm.",colorPalette:{primary:{colorSet:et("#47312F"),isDynamic:!0},secondary:{colorSet:et("#E8F4F5"),isDynamic:!0},accent:{colorSet:et("#2A9D8F"),isThemeColor:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.slate,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"accent",scale:"solid"},foregroundColor:{tint:"neutral",contrast:7}}}}},globalColorOverrides:{background:{base:{category:"secondary",scale:"interactive-bg"},surface:{category:"secondary",scale:"interactive-bg-3"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}})]),typographyStyles:["modern","elegant-serif","bricolage-grotesque","playfair-source","nunito","oswald-source","space-grotesk","unbounded-geist","albert-sans","libre-baskerville","fraunces-open-sans","work-sans-rubik","lexend","figtree","crimson-pro","syne-geist","montagu-slab"],iconStyles:["material","vinyl"],defaultTypographyStyleId:"playfair-source",defaultIconStyleId:"material",themeVisualConfig:{cornerStyle:{type:"rounded",size:"none"}},themableComponentOverrides:{button:{variant:"flat-button"}}},eK=[{platform:"linkedin",url:"https://www.linkedin.com",label:"LinkedIn"},{platform:"instagram",url:"https://www.instagram.com",label:"Instagram"},{platform:"twitter",url:"https://www.x.com",label:"X"}],eJ=_(eG),eY={"header-basic":eJ({sectionType:"header",sectionId:"header-basic",content:{navItems:[{type:"link",link:{label:"Home",actionType:"page",href:"/"}},{type:"dropdown",label:"Services",navItems:[{label:"Career Clarity",actionType:"page",href:"/services/career-clarity"},{label:"Interview Coaching",actionType:"page",href:"/services/interview-coaching"}]},{type:"link",link:{label:"About",actionType:"page",href:"/about"}},{type:"link",link:{label:"Resources",actionType:"page",href:"/resources"}},{type:"link",link:{label:"Contact",actionType:"page",href:"/contact"}}],logo:{type:"text",text:"Ascent Coaching"},buttons:[{label:"Book a Discovery Call",href:"/contact",actionType:"page"}],socialLinks:eK},visualConfig:{navAlignment:"left",showSocial:!1,showButtons:!0}}),"banner-card-and-background-image":eJ({sectionType:"banner",sectionId:"banner-card-and-background-image",content:{heading:"Clarity & Confidence in Your Career",description:"Expert career coaching to help you navigate transitions, land your next role, and build a career that aligns with your strengths and values.",buttons:[{label:"Start Your Journey",href:"#contact",actionType:"section"}],backgroundImage:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770150222812-ottpys.png",alt:"Professional coaching session in modern office"}},visualConfig:{fullscreenOptions:{fillViewport:!0,verticalAlignment:"bottom"}}}),"feature-carousel-accordion":eJ({sectionType:"feature",sectionId:"feature-carousel-accordion",content:{kicker:"How We Help",heading:"Building Career\nConfidence Together",description:"We focus on what matters most: clarity, strategy, and actionable steps. Our coaching approach meets you where you are and helps you move forward with purpose.",items:[{title:"Career Clarity Session",description:"Get a complete picture of your professional strengths, values, and goals. We'll assess where you are today and map out where you want to go—creating a clear starting point for your journey.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770150550313-xyf9a2.png",alt:"Career assessment session with planning materials"}},{title:"Resume & LinkedIn Optimization",description:"Transform your professional story into compelling materials that get noticed. We'll craft a resume and LinkedIn presence that showcases your unique value and attracts the right opportunities.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770150767939-29ikak.png",alt:"Resume review and optimization session"}},{title:"Interview Preparation",description:"Build confidence and master your interview skills. We'll practice common questions, refine your stories, and develop strategies to handle any interview scenario with poise.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770151001835-xxu484.png",alt:"Interview coaching and mock interview practice"}},{title:"Career Transition Strategy",description:"Navigate major career changes with a clear roadmap. Whether you're switching industries, pursuing a promotion, or re-entering the workforce, we'll create your step-by-step action plan.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770151533188-g7ldb2.png",alt:"Career transition planning and goal setting"}},{title:"Ongoing Accountability",description:"Stay on track with regular check-ins and support. We'll celebrate wins, navigate setbacks, and adjust your strategy as opportunities emerge—because career growth is a journey.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770152021687-l6p9hu.png",alt:"Progress tracking and accountability coaching"}}]},visualConfig:{}}),"testimonial-carousel":eJ({sectionType:"testimonial",sectionId:"testimonial-carousel",content:{kicker:"Client Stories",heading:"Real Results from\nReal People",buttons:[{label:"Read More Success Stories",href:"/testimonials",actionType:"page"}],items:[{quote:"I came to Ascent feeling stuck in my career and not knowing what direction to take. Within three months, I had clarity on my goals, landed interviews at top companies, and accepted a role with a 40% salary increase.",name:"Jennifer Martinez",title:"Product Manager",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769725160376-blk6gn.png?w=100&h=100&fit=crop",alt:"Jennifer Martinez"}},{quote:"After being laid off, I felt lost and overwhelmed by the job search. Ascent helped me reframe my experience, polish my resume, and approach interviews with confidence. I'm now in a role I love.",name:"Marcus Thompson",title:"Senior Software Engineer",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769725236492-gf5hw7.png?w=100&h=100&fit=crop",alt:"Marcus Thompson"}},{quote:"I wanted to transition from teaching to corporate training but didn't know how to position myself. The coaching helped me translate my skills and I landed my dream job within two months.",name:"David Chen",title:"Learning & Development Manager",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769737578167-9u616f.png?w=100&h=100&fit=crop",alt:"David Chen"}},{quote:"Returning to work after a career break was daunting. Ascent helped me rebuild my confidence, update my skills story, and negotiate a senior role. They made me feel capable again.",name:"Sarah Williams",title:"Marketing Director",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770074373284-uaacsb.png?w=100&h=100&fit=crop",alt:"Sarah Williams"}},{quote:"I always thought executive coaching was only for C-suite leaders. Ascent showed me that investing in my career development at any level pays dividends. Best decision I've made.",name:"Robert Jackson",title:"Operations Manager",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770075103972-jzfmpg.png?w=100&h=100&fit=crop",alt:"Robert Jackson"}}]},visualConfig:{showDotsOnDesktop:!0}}),"team-grid":eJ({sectionType:"team",sectionId:"team-grid",content:{kicker:"Meet Your Coaches",heading:"Experienced Guides for Your Career Journey",description:"Our certified career coaches bring decades of experience in HR, executive recruitment, and leadership development to help you achieve your professional goals.",items:[{name:"Rachel Ing",role:"Founder & Executive Coach",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770152187028-66avpq.png",alt:"Rachel Ing"},description:"A certified executive coach with 15 years in talent development at Fortune 500 companies, Rachel founded Ascent to provide the personalized career guidance that's often missing in corporate settings. Her practical, empathetic approach has helped hundreds of professionals advance their careers."},{name:"Michael James",role:"Senior Career Coach",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770151671167-a7quw4.png",alt:"Michael James"},description:"Michael specializes in career transitions and leadership development. With a background as an executive recruiter and HR leader, he understands what employers are looking for and how to position you for success."}]},visualConfig:{showImages:!0}}),"faq-accordion":eJ({sectionType:"faq",sectionId:"faq-accordion",content:{kicker:"Questions & Answers",heading:"Frequently Asked Questions",description:"Have more questions? We're happy to chat. Reach out anytime.",buttons:[{label:"Contact Us",href:"/contact",actionType:"page"}],items:[{question:"What's the difference between a career coach and a recruiter?",answer:"A recruiter works for employers to fill specific positions. A career coach works for you—helping you identify your goals, develop your professional brand, improve your job search skills, and navigate your entire career trajectory. We're your partner, not a middleman."},{question:"How much does career coaching cost?",answer:"We offer several coaching packages to fit different needs and budgets. Our initial discovery call is free, where we'll discuss your goals and recommend the best approach. Individual sessions start at $175, and our comprehensive programs offer better value for ongoing support."},{question:"I'm not sure what career I want. Can you still help?",answer:"Absolutely! Many clients come to us feeling uncertain about their direction. Our career clarity process helps you explore your strengths, values, and interests to identify paths that genuinely fit who you are—not just what looks good on paper."},{question:"How long does it typically take to land a new job?",answer:"Every situation is different, but most clients in active job search mode see significant progress within 2-3 months. Factors include your industry, target role, and how much time you can dedicate. We focus on quality opportunities, not just any job."},{question:"Do you help with executive-level positions?",answer:"Yes! We work with professionals at all levels, from early career to C-suite. Our executive coaching includes board positioning, executive presence, salary negotiation for high-stakes offers, and navigating complex organizational dynamics."}]},visualConfig:{contentAlignment:"split"}}),"text-basic":eJ({sectionType:"text",sectionId:"text-basic",content:{kicker:"Our Approach",heading:"Career success starts with clarity.",description:"We don't believe in generic career advice. Our coaching is personalized to your unique strengths, goals, and circumstances—helping you build confidence and a clear path forward."},visualConfig:{alignment:"split"}}),"showcase-grid":eJ({sectionType:"showcase",sectionId:"showcase-grid",content:{kicker:"Credentials",heading:"Certified & trusted",description:"Our coaches hold certifications from leading professional coaching organizations.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-1.svg",alt:"Logo 1"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-2.svg",alt:"Logo 2"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-3.svg",alt:"Logo 3"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-4.svg",alt:"Logo 4"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-5.svg",alt:"Logo 5"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-6.svg",alt:"Logo 6"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-7.svg",alt:"Logo 7"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-8.svg",alt:"Logo 8"}]},visualConfig:{contentAlignment:"center",itemSize:"md"}}),"gallery-grid":eJ({sectionType:"gallery",sectionId:"gallery-grid",content:{kicker:"Our Space",heading:"Where clarity\nfinds you.",description:"Our welcoming coaching environment is designed to help you think clearly and plan confidently.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770152019413-4zyqjg.png",alt:"Modern coaching office reception"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770152019980-6npbvl.png",alt:"One-on-one coaching session"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770152070129-tv6ou1.png",alt:"Career planning session"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770152026847-myzbcr.png",alt:"Professional development workshop"}]},visualConfig:{}}),"metrics-basic":eJ({sectionType:"metrics",sectionId:"metrics-basic",content:{kicker:"Results",heading:"Our clients'\nsuccess speaks.",description:"Real outcomes from professionals who invested in their career growth.",items:[{metric:"92%",title:"Land New Roles",description:"Within 90 days of completing our program"},{metric:"35%",title:"Average Salary Increase",description:"When negotiating new offers"},{metric:"4.9",title:"★★★★★",description:"Based on post-coaching surveys"},{metric:"500+",title:"Careers Transformed",description:"Professionals we've coached to success"}]},visualConfig:{}}),"pricing-table":eJ({sectionType:"pricing",sectionId:"pricing-table",content:{kicker:"Coaching Packages",heading:"Invest in your\ncareer growth.",description:"Choose the coaching package that fits your needs. All packages include our satisfaction guarantee.",items:[{isFeatured:!1,title:"Single Session",price:"$175",description:"Perfect for tackling a specific career challenge or getting expert advice.",features:[{title:"60-minute deep dive"},{title:"Action plan included"},{title:"Email follow-up"},{title:"Resource recommendations"}],button:{label:"Book Session",href:"/contact",actionType:"page"}},{isFeatured:!0,badgeLabel:"Most Popular",title:"Career Accelerator",price:"$1,499",description:"Comprehensive 8-week program for job seekers ready for their next role.",features:[{title:"Weekly coaching calls"},{title:"Resume & LinkedIn overhaul"},{title:"Interview preparation"},{title:"Salary negotiation coaching"},{title:"Unlimited email support"}],button:{label:"Start Program",href:"/contact",actionType:"page"}},{isFeatured:!1,title:"Executive Coaching",price:"$3,500",description:"Premium 3-month engagement for senior leaders and executives.",features:[{title:"Bi-weekly coaching sessions"},{title:"Executive presence coaching"},{title:"Leadership assessment"},{title:"Board positioning strategy"},{title:"Priority access & support"}],button:{label:"Schedule Consultation",href:"/contact",actionType:"page"}}]},visualConfig:{}}),"cta-basic":eJ({sectionType:"cta",sectionId:"cta-basic",content:{heading:"Ready to Take Your Career to the Next Level?",description:"Book a free discovery call and let's discuss how we can help you gain clarity, build confidence, and create a career strategy that works for you.",buttons:[{label:"Book Free Discovery Call",href:"/contact",actionType:"page"},{label:"Learn More",href:"/services",actionType:"page"}]},visualConfig:{textAlignment:"split"}}),"contact-form-text":eJ({sectionType:"contact",sectionId:"contact-form-text",content:{kicker:"Get Started",heading:"Book your free discovery call.",description:"Tell us about your career goals and we'll reach out to schedule your complimentary consultation.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"What career goals would you like to achieve?",submitButtonLabel:"Request Discovery Call",formConfig:{contactEmail:"hello@ascentcoaching.com",contactPhone:"(312) 555-0192",contactAddress:"200 Professional Plaza, Suite 450, Chicago, IL 60601",successTitle:"Request received!",successMessage:"We'll be in touch within 24 hours to schedule your free discovery call.",successButtonLabel:"Send another message"}},visualConfig:{contentAlignment:"split"}}),"contact-form-map":eJ({sectionType:"contact",sectionId:"contact-form-map",content:{kicker:"Contact us",heading:"Let's discuss your next move",description:"Send us a message and we'll reply within one business day.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"How can we help?",submitButtonLabel:"Send Message",formConfig:{successTitle:"Request received!",successMessage:"We'll be in touch soon.",successButtonLabel:"Send another message"},map:{address:"350 Summit Street, Denver, CO 80202"}},visualConfig:{mapPosition:"right",mapType:"roadmap",zoom:15}}),"location-map":eJ({sectionType:"location",sectionId:"location-map",content:{address:"350 Summit Street, Denver, CO 80202"},visualConfig:{mapType:"roadmap",zoom:15}}),"location-text-and-map":eJ({sectionType:"location",sectionId:"location-text-and-map",content:{kicker:"Visit us",heading:"Find us nearby \n and stop by today.",description:"Use the map to get directions and visit our location.",map:{address:"350 Summit Street, Denver, CO 80202"}},visualConfig:{mapPositionOptions:{mapPosition:"right"},mapType:"roadmap",zoom:15,fillViewportOptions:{fillViewport:!1}}}),"footer-info-grid":eJ({sectionType:"footer",sectionId:"footer-info-grid",content:{logo:{type:"text",text:"Ascent Coaching"},navItems:[{label:"Home",href:"/",actionType:"page"},{label:"Services",href:"/services",actionType:"page"},{label:"About",href:"/about",actionType:"page"},{label:"Resources",href:"/resources",actionType:"page"},{label:"Blog",href:"/blog",actionType:"page"},{label:"Contact",href:"/contact",actionType:"page"},{label:"Success Stories",href:"/testimonials",actionType:"page"},{label:"FAQ",href:"/faq",actionType:"page"},{label:"Book a Call",href:"/book",actionType:"page"},{label:"Free Resources",href:"/free-resources",actionType:"page"}],legalLinks:[{label:"Privacy Policy",href:"/privacy",actionType:"page"},{label:"Terms of Service",href:"/terms",actionType:"page"}],socialLinks:eK,copyright:"© 2026 Ascent Career Coaching. All rights reserved.",address:"200 Professional Plaza, Suite 450, Chicago, IL 60601",contact:"(312) 555-0192\nhello@ascentcoaching.com"},visualConfig:{showSocial:!0,showLegalLinks:!0}})},eX={colorSchemeId:eH.colorSchemes[0].id,themeColorOverride:"#1E3A5F",typographyStyleId:"crimson-pro",content:{header:eY["header-basic"],content:[eY["banner-card-and-background-image"],eY["feature-carousel-accordion"],eY["testimonial-carousel"],eY["team-grid"],eY["text-basic"],eY["showcase-grid"],eY["gallery-grid"],eY["faq-accordion"],eY["metrics-basic"],eY["pricing-table"],eY["contact-form-text"],eY["contact-form-map"],eY["location-text-and-map"],eY["location-map"],eY["cta-basic"]],footer:eY["footer-info-grid"]}},eQ=T({id:"steady-ascent",name:"Steady Ascent",description:"A polished, aspirational design that balances professionalism with approachability. Features moderate saturation colors with warm accent tones, clean backgrounds, and clear typographic hierarchy. Structured layouts with subtle visual interest convey competence without being cold. Best for career coaches, executive coaches, leadership consultants, business mentors, professional development trainers, HR consultancies, and personal branding services where building trust and inspiring growth are key.",previewImage:"https://example.com/image.jpg",sections:eG,themeConfig:eH,previewSchema:eX,tags:["professional services","education","personal"],isPublished:!0,examples:eY}),e0={header:{"header-basic":{overrides:{navAlignment:"left",showSocial:!1,showButtons:!0}}},banner:{"banner-diagonal-grid":{}},feature:{"feature-three-card":{}},gallery:{"gallery-grid":{}},text:{"text-basic":{overrides:{alignment:"split"}}},showcase:{"showcase-grid":{overrides:{contentAlignment:"center",itemSize:"md"}}},metrics:{"metrics-numbers":{}},team:{"team-grid":{overrides:{showImages:!0}}},testimonial:{"testimonial-grid":{}},pricing:{"pricing-table":{}},faq:{"faq-accordion":{overrides:{contentAlignment:"split"}}},cta:{"cta-background-image":{overrides:{textAlignment:"split"}}},contact:{"contact-form-text":{overrides:{contentAlignment:"split"}},"contact-form-map":{}},location:{"location-map":{},"location-text-and-map":{}},footer:{"footer-logo-nav":{overrides:{showLegalLinks:!0}}}},e1={colorSchemes:eo([D({id:"bold-contrast",name:"Bold Contrast",category:"preferred",description:"A bold, dramatic color palette featuring dark blue backgrounds, with high-contrast white text. The primary scale uses the darkest blues for backgrounds, creating a sophisticated, gallery-quality visual impact. Ideal for photography portfolios, creative agencies, art galleries, and visual designers seeking striking, professional presence with deep blue tones.",colorPalette:{primary:{colorSet:et("#E5E5E5")},secondary:{colorSet:et("#20262C"),isDynamic:!0},accent:{colorSet:et("#4F46E5"),isThemeColor:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.gray,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"accent",scale:"solid"},foregroundColor:{tint:"white",contrast:7}}}}},globalColorOverrides:{foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),D({id:"dark-contrast",name:"Dark Contrast",category:"preferred",description:"A bold, dramatic dark color palette featuring deep charcoal backgrounds with high-contrast light text. The primary scale uses the darkest tones for backgrounds, creating a sophisticated, gallery-quality visual impact. Ideal for photography portfolios, creative agencies, art galleries, and visual designers seeking striking, professional presence with dark moody tones.",colorPalette:{primary:{colorSet:et("#1A1A1A"),isDynamic:!0},secondary:{colorSet:et("#E5E5E5"),isDynamic:!0},accent:{colorSet:et("#EAB308"),isThemeColor:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.gray,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"accent",scale:"solid"},foregroundColor:{tint:"black",contrast:7}},secondary:{backgroundColor:{category:"primary",scale:"foreground-subtle"},foregroundColor:{category:"primary",scale:"canvas-bg"}}}}},globalColorOverrides:{background:{base:{category:"primary",scale:"canvas-bg",isInverted:!0},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}})]),typographyStyles:["modern","elegant-serif","bricolage-grotesque","playfair-source","nunito","oswald-source","space-grotesk","unbounded-geist","albert-sans","libre-baskerville","fraunces-open-sans","work-sans-rubik","lexend","figtree","crimson-pro","syne-geist","montagu-slab"],iconStyles:["material","vinyl"],defaultTypographyStyleId:"figtree",defaultIconStyleId:"material",themeVisualConfig:{cornerStyle:{type:"rounded",size:"none"}},themableComponentOverrides:{button:{variant:"flat-button"}}},e2=_(e0),e3={"header-basic":e2({sectionType:"header",sectionId:"header-basic",content:{navItems:[{type:"link",link:{label:"Home",actionType:"page",href:"/"}},{type:"dropdown",label:"Portfolio",navItems:[{label:"Weddings",actionType:"page",href:"/portfolio/weddings"},{label:"Portraits",actionType:"page",href:"/portfolio/portraits"}]},{type:"link",link:{label:"Services",actionType:"page",href:"/services"}},{type:"link",link:{label:"About",actionType:"page",href:"/about"}},{type:"link",link:{label:"Contact",actionType:"page",href:"/contact"}}],logo:{type:"text",text:"Aperture House"},buttons:[{label:"Book Session",href:"/book",actionType:"page"}],socialLinks:[{platform:"instagram",url:"https://www.instagram.com",label:"Instagram"},{platform:"facebook",url:"https://www.facebook.com",label:"Facebook"},{platform:"youtube",url:"https://www.youtube.com",label:"YouTube"}]},visualConfig:{navAlignment:"left",showButtons:!0,showSocial:!1}}),"banner-diagonal-grid":e2({sectionType:"banner",sectionId:"banner-diagonal-grid",content:{heading:"Every moment \ndeserves to be\ntimeless.",description:"From weddings to portraits, commercial shoots to creative concepts—we capture the stories that matter most with artistry and precision.",buttons:[{label:"View Portfolio",href:"#portfolio",actionType:"section"}],image1:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770157200593-nkkyla.png",alt:"Professional photography studio setup"},image2:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770155301949-xlpj8y.png",alt:"Creative photography workspace"}},visualConfig:{}}),"feature-three-card":e2({sectionType:"feature",sectionId:"feature-three-card",content:{kicker:"Our Approach",heading:"Capturing life's \nmost important moments.",description:"Whether it's the biggest day of your life or a quiet portrait session, we bring artistry, technical excellence, and a keen eye for detail to every shoot.",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770158458739-k3j4mu.png",alt:"Professional photography session"},items:[{title:"Artistry & Vision",description:"We approach every shoot with a creative eye, finding the perfect angles, lighting, and compositions that transform ordinary moments into extraordinary images."},{title:"Technical Excellence",description:"From camera settings to post-processing, we leverage years of expertise and professional-grade equipment to deliver stunning, gallery-quality results."}]},visualConfig:{}}),"testimonial-grid":e2({sectionType:"testimonial",sectionId:"testimonial-grid",content:{kicker:"Client Reviews",heading:"What our clients \nare saying.",buttons:[{label:"Read More Reviews",href:"#",actionType:"section"}],items:[{quote:"The photos from our wedding are absolutely stunning. They captured every moment we hoped for and so many we didn't even know were happening. Pure magic.",name:"Emily Rodriguez",title:"Wedding Clients",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769721319953-oqgv9d.png",alt:"Emily Rodriguez"}},{quote:"Professional, creative, and so easy to work with. My headshots have opened doors I didn't think possible. Worth every penny.",name:"Marcus Johnson",title:"Corporate Headshots",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770151671167-a7quw4.png",alt:"Marcus Johnson"}},{quote:"Our product photography has transformed our e-commerce sales. The images are crisp, beautiful, and exactly what we needed to elevate our brand.",name:"Sarah Chen",title:"Small Business Owner",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769725152412-4m4ggp.png",alt:"Sarah Chen"}},{quote:"I've never felt more comfortable in front of a camera. The session was fun, relaxed, and the photos are incredible. I actually like how I look!",name:"David Thompson",title:"Portrait Client",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1769721406765-ss0dre.png",alt:"David Thompson"}}]},visualConfig:{}}),"gallery-grid":e2({sectionType:"gallery",sectionId:"gallery-grid",content:{kicker:"",heading:"Recent Work",description:"",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/a3b9ed1a-28ac-4ff4-8556-edcbf6ccdc6e-DwDHcYankHMl83ZUlLQtLLCDKuiGvI.png",alt:"Wedding photography"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/ff3470c2-d75d-4223-99fa-541af50fa3ab-qSXHxV7bMtWDS1Ptt0Wt4IvRi9Z5iA.png",alt:"Creative photography shot"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/f5a3601d-bafc-4ecb-93f8-4f3966312058-kpgvpfWfTj4NbCLxtcKooWwGfIw2Vc.png",alt:"Professional photo session"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/9e249425-f75d-41ba-b6f7-1f33aab2d01d-Q1gaIZWIgKAK3gSoSAfjDmhVVsU2KD.png",alt:"Corporate photography"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/286160b5-f686-4367-b390-c4288279548f-DPkcN68cNW1IPSibMYgWf7PPdmWQQt.png",alt:"Portrait session work"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/infinite-images/e9b86f98-598c-457e-841d-dc1ec8e62273-eCfadmS5yRxfCi2wF702uPi7Sf2NtM.png",alt:"Family photography"}]},visualConfig:{}}),"team-grid":e2({sectionType:"team",sectionId:"team-grid",content:{kicker:"Meet the Team",heading:"Artists behind \nthe camera.",description:"Our team of experienced photographers brings diverse perspectives, technical expertise, and a shared passion for visual storytelling.",items:[{name:"Amira Saleh",role:"Lead Photographer & Creative Director",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770159319831-x3zvdn.png",alt:"Amira Saleh"},description:"15 years experience in wedding and portrait photography. Featured in several industry publications."},{name:"Mateo Torres",role:"Commercial & Product Photographer",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770158814259-ugh0g5.png",alt:"Mateo Torres"},description:"Specialized in commercial work for brands and small businesses. Expert in lighting and composition."},{name:"Sam Tanaka",role:"Portrait & Editorial Photographer",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770159187745-hshybf.png",alt:"Sam Tanaka"},description:"Fine art photographer with a background in editorial work. Brings an artistic eye to every project."}]},visualConfig:{showImages:!0}}),"cta-background-image":e2({sectionType:"cta",sectionId:"cta-background-image",content:{heading:"Give the gift of a photo book.",description:"Preserve your favorite moments in a beautifully crafted, professionally printed photo book. Custom layouts, premium materials, and memories that last a lifetime.",backgroundImage:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770159396974-tim8xc.png",alt:"Hands examining portfolio book pages "},buttons:[{label:"Design Your Book",href:"#",actionType:"section"},{label:"View Samples",href:"#",actionType:"section"}]},visualConfig:{textAlignment:"split"}}),"faq-accordion":e2({sectionType:"faq",sectionId:"faq-accordion",content:{kicker:"Common Questions",heading:"Frequently Asked Questions",description:"Everything you need to know about our photography services, packages, and process.",buttons:[],items:[{question:"How far in advance should I book?",answer:"For weddings, we recommend booking 9-12 months in advance. Portrait and commercial sessions can typically be scheduled 2-4 weeks out, depending on availability."},{question:"What's included in your packages?",answer:"All packages include the photo session, professional editing, and a private online gallery. Wedding packages also include engagement sessions and albums. Specific deliverables vary by package—contact us for detailed information."},{question:"Do you travel for shoots?",answer:"Absolutely! We love destination weddings and shoots. Travel fees apply for locations outside our local area, but we're always excited to explore new places."},{question:"How long until we receive our photos?",answer:"Standard turnaround is 2-3 weeks for portrait sessions and 4-6 weeks for weddings. Rush delivery is available for an additional fee if you need photos sooner."},{question:"Can we request specific editing styles?",answer:"Yes! We offer several editing styles from natural and timeless to bold and cinematic. During your consultation, we'll discuss your preferences and show you examples."}]},visualConfig:{contentAlignment:"split"}}),"pricing-table":e2({sectionType:"pricing",sectionId:"pricing-table",content:{kicker:"Photography Packages",heading:"Investment in memories.",description:"Transparent pricing for professional photography services. All packages include editing and online gallery.",items:[{isFeatured:!1,title:"Portrait Essentials",description:"Perfect for headshots, family portraits, and personal branding.",price:"$350",features:[{title:"1-hour photo session"},{title:"20 edited high-res images"},{title:"Private online gallery"},{title:"Download rights included"}],button:{label:"Book Session",href:"/book",actionType:"page"}},{isFeatured:!1,badgeLabel:"Most Popular",title:"Commercial Pro",description:"For businesses, products, and marketing campaigns.",price:"$850",features:[{title:"4-hour photo session"},{title:"50 edited high-res images"},{title:"On-location or studio"},{title:"Commercial usage rights"},{title:"Rush delivery available"}],button:{label:"Get Started",href:"/contact",actionType:"page"}},{isFeatured:!1,title:"Wedding Complete",description:"Full-day coverage for your special day.",price:"$3,200",features:[{title:"8 hours of coverage"},{title:"Engagement session included"},{title:"300+ edited images"},{title:"Second photographer"},{title:"Premium album included"},{title:"USB drive with all files"}],button:{label:"View Details",href:"/weddings",actionType:"page"}}]},visualConfig:{}}),"showcase-grid":e2({sectionType:"showcase",sectionId:"showcase-grid",content:{kicker:"",heading:"Featured Clients",description:"",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-1.svg",alt:"Logo 1"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-2.svg",alt:"Logo 2"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-3.svg",alt:"Logo 3"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-4.svg",alt:"Logo 4"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-5.svg",alt:"Logo 5"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-6.svg",alt:"Logo 6"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-7.svg",alt:"Logo 7"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-8.svg",alt:"Logo 8"}],logoTags:["salon","spa"]},visualConfig:{contentAlignment:"center",itemSize:"md"}}),"contact-form-text":e2({sectionType:"contact",sectionId:"contact-form-text",content:{kicker:"Get In Touch",heading:"Let's discuss your project.",description:"Have a question or ready to book? Send us a message and we'll respond within 24 hours.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"Tell us about your photography needs",submitButtonLabel:"Send Message",formConfig:{contactEmail:"hello@aperturehouse.com",contactPhone:"+1 (555) 789-0123",contactAddress:"456 Studio Ave, Creative District, CA",successTitle:"Message Received!",successMessage:"We'll be in touch soon.",successButtonLabel:"Send another message"}},visualConfig:{contentAlignment:"split"}}),"text-basic":e2({sectionType:"text",sectionId:"text-basic",content:{kicker:"Our Approach",heading:"Every frame tells a story.",description:"We believe photography is more than capturing moments—it's about preserving the emotions, connections, and memories that make life meaningful."},visualConfig:{alignment:"split"}}),"metrics-numbers":e2({sectionType:"metrics",sectionId:"metrics-numbers",content:{kicker:"Our Impact",heading:"Moments captured, memories preserved.",description:"Over the years, we've had the privilege of documenting life's most precious moments.",items:[{metric:"500+",label:"Weddings Captured"},{metric:"2K+",label:"Portrait Sessions"},{metric:"150+",label:"Commercial Clients"},{metric:"10+",label:"Years Experience"}]},visualConfig:{}}),"contact-form-map":e2({sectionType:"contact",sectionId:"contact-form-map",content:{kicker:"Get in Touch",heading:"Let's plan your next shoot",description:"Tell us about your project and we'll get back to you shortly.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"Tell us about your shoot",submitButtonLabel:"Send Message",formConfig:{successTitle:"Thank you!",successMessage:"We'll be in touch soon.",successButtonLabel:"Send another message"},map:{address:"412 Gallery Row, Brooklyn, NY 11201"}},visualConfig:{mapPosition:"right",mapType:"roadmap",zoom:15}}),"location-map":e2({sectionType:"location",sectionId:"location-map",content:{address:"412 Gallery Row, Brooklyn, NY 11201"},visualConfig:{mapType:"roadmap",zoom:15}}),"location-text-and-map":e2({sectionType:"location",sectionId:"location-text-and-map",content:{kicker:"Visit us",heading:"Find us nearby \n and stop by today.",description:"Use the map to get directions and visit our location.",map:{address:"412 Gallery Row, Brooklyn, NY 11201"}},visualConfig:{mapPositionOptions:{mapPosition:"right"},mapType:"roadmap",zoom:15,fillViewportOptions:{fillViewport:!1}}}),"footer-logo-nav":e2({sectionType:"footer",sectionId:"footer-logo-nav",content:{logo:{type:"text",text:"Aperture House"},navItems:[{label:"Home",href:"/",actionType:"page"},{label:"Portfolio",href:"/portfolio",actionType:"page"},{label:"Services",href:"/services",actionType:"page"},{label:"About",href:"/about",actionType:"page"},{label:"Contact",href:"/contact",actionType:"page"}],legalLinks:[{label:"Privacy Policy",href:"/privacy",actionType:"page"},{label:"Terms of Service",href:"/terms",actionType:"page"}],copyright:"© 2026 Aperture House Photography. Capturing moments that matter."},visualConfig:{showLegalLinks:!0}})},e5={colorSchemeId:e1.colorSchemes[0].id,themeColorOverride:"#0A0A0A",typographyStyleId:"figtree",content:{header:e3["header-basic"],content:[e3["banner-diagonal-grid"],e3["feature-three-card"],e3["gallery-grid"],e3["text-basic"],e3["showcase-grid"],e3["metrics-numbers"],e3["team-grid"],e3["testimonial-grid"],e3["pricing-table"],e3["faq-accordion"],e3["cta-background-image"],e3["contact-form-text"],e3["contact-form-map"],e3["location-text-and-map"],e3["location-map"]],footer:e3["footer-logo-nav"]}},e4=T({id:"true-exposure",name:"True Exposure",description:"A minimal, high-contrast gallery aesthetic with sharp 0px corners and clean typography. Features dramatic dark-on-light or light-on-dark color schemes with monochromatic palettes that make imagery the focal point. Clean grid layouts, generous whitespace, and flat buttons create a sophisticated editorial feel. Best for visual-heavy businesses: photography studios, art galleries, design portfolios, architecture firms, and creative agencies where letting work speak for itself is paramount.",previewImage:"https://example.com/image.jpg",sections:e0,themeConfig:e1,previewSchema:e5,tags:["creative","professional services"],isPublished:!0,examples:e3}),e6={header:{"header-marketer":{overrides:{navAlignment:"right",showButtons:!0}}},banner:{"banner-bento-grid":{overrides:{fillViewport:!0}}},feature:{"feature-bento-grid":{},"feature-carousel":{},"feature-carousel-accordion":{}},gallery:{"gallery-grid":{}},text:{"text-basic":{overrides:{alignment:"center"}}},showcase:{"showcase-grid":{overrides:{contentAlignment:"center",itemSize:"md"}}},metrics:{"metrics-basic":{}},testimonial:{"testimonial-carousel":{}},team:{"team-grid":{overrides:{showImages:!0}}},pricing:{"pricing-table":{}},faq:{"faq-accordion":{overrides:{contentAlignment:"center"}}},cta:{"cta-basic":{overrides:{textAlignment:"split"}},"cta-background-image":{overrides:{textAlignment:"center"}}},contact:{"contact-form-image":{overrides:{imagePosition:"right"}},"contact-form-map":{}},location:{"location-map":{},"location-text-and-map":{}},footer:{"footer-logo-nav":{overrides:{showLegalLinks:!0}}}},e7={colorSchemes:eo([D({id:"bold-contrast",name:"Bold Contrast",category:"preferred",description:"A bold, high-energy color palette featuring deep, dark navy primary tones paired with vibrant, high-saturation bright green secondary accents. The primary offers low brightness with moderate saturation, creating a sophisticated dark canvas. The secondary provides maximum saturation and brightness for energetic accent colors that pop with intensity. High contrast between dark backgrounds and bright accents creates a sleek, powerful atmosphere. Ideal for fitness, sports, urban lifestyle, and action-oriented brands seeking a modern, high-performance aesthetic.",colorPalette:{primary:{colorSet:et("#212736")},secondary:{colorSet:et("#00FF48"),isThemeColor:!0},accent:{colorSet:et("#FF6B00"),isDynamic:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.slate,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"secondary",scale:"canvas-bg-2"},hoverBackgroundColor:{category:"secondary",scale:"interactive-bg"}}}}},globalColorOverrides:{background:{base:{category:"primary",scale:"interactive-bg",isInverted:!0},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),D({id:"electric-vitality",name:"Electric Vitality",category:"preferred",description:"A clean, high-energy light palette featuring crisp, high-brightness backgrounds paired with vibrant electric green accents. The primary scale offers maximum brightness with minimal saturation for an airy, fresh canvas. The secondary provides maximum saturation electric green that ensures key actions pop with intense energy while maintaining a modern, performance-driven aesthetic. Clear brightness contrast between light backgrounds and vivid green accents creates dynamic visual hierarchy. Perfect for fitness, sports, and action-oriented brands seeking an accessible yet high-energy appearance.",colorPalette:{primary:{colorSet:et("#F0F2F5")},secondary:{colorSet:et("#39FF14"),isThemeColor:!0},accent:{colorSet:et("#7C3AED"),isDynamic:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.slate,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"overlay",tint:"accent",contrast:10},foregroundColor:{tint:"neutral",contrast:7}}}}},globalColorOverrides:{background:{base:{category:"primary",scale:"interactive-bg"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}})]),typographyStyles:["elegant-serif","modern","bricolage-grotesque","playfair-source","nunito","oswald-source","oswald-inter","space-grotesk","unbounded-geist","albert-sans","libre-baskerville","fraunces-open-sans","work-sans-rubik","lexend","figtree","crimson-pro","syne-geist","montagu-slab"],iconStyles:["material","vinyl"],defaultTypographyStyleId:"oswald-inter",defaultIconStyleId:"material",themeVisualConfig:{cornerStyle:{type:"rounded",size:"2xl"}},themableComponentOverrides:{button:{variant:"flat-button",config:{borderRadius:"xl"}}}},e9=_(e6),e8={"header-marketer":e9({sectionType:"header",sectionId:"header-marketer",content:{navItems:[{type:"link",link:{label:"Home",actionType:"page",href:"/"}},{type:"dropdown",label:"Programs",navItems:[{label:"Strength Training",actionType:"page",href:"/programs/strength-training"},{label:"HIIT Classes",actionType:"page",href:"/programs/hiit-classes"}]},{type:"link",link:{label:"Trainers",actionType:"page",href:"/trainers"}},{type:"link",link:{label:"Schedule",actionType:"page",href:"/schedule"}},{type:"link",link:{label:"Join",actionType:"page",href:"/join"}}],logo:{type:"text",text:"FORGE"},buttons:[{label:"Start Free Trial",href:"/trial",actionType:"page"}]},visualConfig:{navAlignment:"right",showButtons:!0}}),"banner-bento-grid":e9({sectionType:"banner",sectionId:"banner-bento-grid",content:{heading:"Build strength. \nFind focus. \nOwn your goals.",description:"Premium equipment meets expert coaching in a space designed for serious results. Train with athletes who get it.",buttons:[{label:"Start Your Journey",href:"#join",actionType:"section"}],images:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/personal-trainer-assisting-cable-row.png?w=1920&h=1080&fit=crop",alt:"Personal trainer assisting a man with a cable exercise in a gym."},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/woman-running-on-treadmill-gym.png?w=800&h=600&fit=crop",alt:"Woman running on a treadmill in a gym."}]},visualConfig:{fillViewport:!0}}),"feature-bento-grid":e9({sectionType:"feature",sectionId:"feature-bento-grid",content:{kicker:"The FORGE Difference",heading:"Built for \nserious athletes.",description:"We've created an environment where nothing stands between you and your goals. Every detail is designed for performance.",buttons:[{label:"Book a Tour",href:"#",actionType:"section"}],items:[{type:"text",title:"Elite Equipment",description:"Rogue, Eleiko, and Assault—we invest in the best so you can train at the highest level.",isInverted:!1},{type:"text",title:"24/7 Access",description:"Your schedule, your rules. Train whenever inspiration strikes with round-the-clock facility access.",isInverted:!1},{type:"image",src:"https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800",alt:"Premium gym floor"},{type:"image",src:"https://images.unsplash.com/photo-1576678927484-cc907957088c?w=800&q=80",alt:"Recovery area"},{type:"text",title:"Recovery Zone",description:"Cryotherapy, saunas, and massage guns. Recover faster and come back stronger every session.",isInverted:!1},{type:"text",title:"Community First",description:"Join a tribe of like-minded athletes who motivate, challenge, and celebrate each other.",isInverted:!0}]},visualConfig:{}}),"feature-carousel":e9({sectionType:"feature",sectionId:"feature-carousel",content:{items:[{title:"Assess & Plan",kicker:"Week 1",description:"Comprehensive fitness assessment, body composition analysis, and personalized goal setting with your coach.",image:{src:"https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1600&q=80",alt:"Fitness assessment"},buttons:[{label:"Learn More",actionType:"section",href:"#assess"}]},{title:"Build Foundation",kicker:"Weeks 2-4",description:"Master proper form, establish training habits, and build the base for long-term progress.",image:{src:"https://images.unsplash.com/photo-1581009146145-b5ef050c149a?w=1600&q=80",alt:"Foundation training"},buttons:[{label:"See Process",actionType:"section",href:"#build"}]},{title:"Push Limits",kicker:"Weeks 5+",description:"Progressive overload and advanced programming to continuously challenge your body and break plateaus.",image:{src:"https://images.unsplash.com/photo-1526506118085-60ce8714f8c5?w=1600&q=80",alt:"Intense training session"},buttons:[{label:"Get Started",actionType:"section",href:"#push"}]}]},visualConfig:{}}),"feature-carousel-accordion":e9({sectionType:"feature",sectionId:"feature-carousel-accordion",content:{heading:"Class Schedule",description:"From sunrise to late night, we have classes that fit your schedule and challenge every part of your fitness.",items:[{title:"Morning Power Hour",description:"Start your day with an explosive 60-minute session combining strength and cardio. 5:30am and 6:30am daily.",image:{src:"https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1600&q=80",alt:"Early morning workout class"}},{title:"Lunchtime HIIT",description:"Maximum results in minimum time. Our 45-minute lunch sessions are perfect for busy professionals.",image:{src:"https://images.unsplash.com/photo-1549060279-7e168fcee0c2?w=1600&q=80",alt:"HIIT class in action"}},{title:"Evening Strength",description:"Dedicated strength training sessions with coach guidance. Build muscle and perfect your lifts.",image:{src:"https://images.unsplash.com/photo-1526506118085-60ce8714f8c5?w=1600&q=80",alt:"Evening strength class"}},{title:"Fight Night",description:"Boxing and MMA training every Tuesday and Thursday. All skill levels welcome.",image:{src:"https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=1600&q=80",alt:"Fight training class"}},{title:"Weekend Warriors",description:"Special Saturday sessions featuring team workouts, competitions, and community challenges.",image:{src:"https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1600&q=80",alt:"Weekend group workout"}}]},visualConfig:{}}),"testimonial-carousel":e9({sectionType:"testimonial",sectionId:"testimonial-carousel",content:{kicker:"Member Stories",heading:"Real people. \nReal progress.",buttons:[{label:"See More Stories",href:"#",actionType:"section"}],items:[{quote:"Down 40 pounds in six months, but honestly? The mental shift was even bigger. I came in thinking I just needed to lose weight, but FORGE taught me how to move properly, eat smarter, and actually enjoy the process. Now I'm chasing PRs instead of just trying to look better. This place completely rewired how I think about fitness.",name:"Marcus Williams",title:"Lost 40 lbs in 6 months",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/man-seated-cable-row-gym.png?w=100&h=100&fit=crop",alt:"Marcus Williams"}},{quote:"I compete nationally in powerlifting, so my standards are high. The equipment here is legit—Rogue racks, Eleiko bars, calibrated plates. But it's the coaching that sets FORGE apart. They understand programming, they know when to push and when to back off, and they actually care about your goals. No compromises, no excuses, just solid training every single day.",name:"Jasmine Torres",title:"National Powerlifting Competitor",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/woman-dumbbell-row-gym.png?w=100&h=100&fit=crop",alt:"Jasmine Torres"}},{quote:"Best part about FORGE? The people. Everyone's grinding toward something—whether it's their first pull-up or a competition prep. Nobody's showing off, nobody's judging. You just show up, work hard, and somehow everyone else's energy makes you push a little harder. It's contagious in the best way possible. I've made some of my closest friends here.",name:"Ryan Chen",title:"Member since 2021",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/man-barbell-bicep-curl-gym.png?w=100&h=100&fit=crop",alt:"Ryan Chen"}},{quote:"I've bounced around to every gym in town—big chains, boutique studios, you name it. This is the first one I actually get excited to show up to. The vibe is just different. Great equipment, knowledgeable staff, and zero pretension. Whether I'm hitting a heavy deadlift day or just need to move after sitting at my desk all day, I know I'm walking into the right place.",name:"Aisha Johnson",title:"Fitness Enthusiast",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/woman-leg-press-gym.png?w=100&h=100&fit=crop",alt:"Aisha Johnson"}}]},visualConfig:{}}),"gallery-grid":e9({sectionType:"gallery",sectionId:"gallery-grid",content:{kicker:"Our Space",heading:"Where effort \nmeets equipment.",description:"15,000 square feet packed with everything you need to train hard, recover smart, and level up daily.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/free-weights-dumbbells-gym-interior.png?w=800",alt:"Rows of dumbbells in a gym."},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/deadlift-barbell-grip-closeup.png?w=800&q=80",alt:"Hands gripping a barbell during a deadlift in a gym."},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/boxer-wrapping-gloves-gym.png?w=800&q=80",alt:"Woman putting on boxing gloves in a gym."},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/modern-gym-interior-equipment.png?w=800&q=80",alt:"Modern gym interior with treadmills, squat racks, and free weights near large windows."},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/strength-conditioning-gym-turf-area.png?w=800&q=80",alt:"Modern gym training area with cable machines, suspension straps, battle ropes, and turf."}]}}),"team-grid":e9({sectionType:"team",sectionId:"team-grid",content:{kicker:"Meet Your Coaches",heading:"Pros who \nlive this life.",description:"Every coach here has competed, recovered, and come back stronger. They know the work because they've done it.",items:[{name:"Derek Stone",role:"Head Coach & Founder",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/fitness-trainer-headshot-gym.png?w=400&h=400&fit=crop",alt:"Portrait of a man standing in a gym"},description:"15+ years as an NFL strength coach. Now helping athletes at every level hit PRs and break through plateaus."},{name:"Mia Rodriguez",role:"HIIT & Conditioning Specialist",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/woman-fitness-portrait-gym.png?w=400&h=400&fit=crop",alt:"Portrait of a woman standing in a gym"},description:"CrossFit Games competitor and nutrition coach. Her classes are intense, but everyone leaves feeling accomplished."},{name:"Kai Thompson",role:"Combat Sports Coach",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/personal-trainer-portrait-gym.png?w=400&h=400&fit=crop",alt:"Kai Thompson"},description:"Pro MMA fighter (12-2) teaching striking fundamentals and fight-ready conditioning to all skill levels."}]},visualConfig:{showImages:!0}}),"pricing-table":e9({sectionType:"pricing",sectionId:"pricing-table",content:{kicker:"Membership Plans",heading:"Pick your \ntraining level.",description:"Every membership gets you 24/7 access, premium gear, and a crew that shows up ready to work. Scale up anytime.",items:[{isFeatured:!1,title:"Basic",price:"$79",period:"/month",description:"Everything you need to train hard and stay consistent, no extras required.",features:[{title:"24/7 facility access"},{title:"All premium equipment"},{title:"Free fitness assessment"},{title:"Community support"}],button:{label:"Get Started",href:"#",actionType:"section"}},{isFeatured:!0,badgeLabel:"Most Popular",title:"Elite",price:"$129",period:"/month",description:"Add unlimited classes, recovery tools, and nutrition guidance to accelerate your progress.",features:[{title:"Everything in Basic"},{title:"Unlimited group classes"},{title:"Priority trainer access"},{title:"Recovery zone access"},{title:"Nutrition consultation"}],button:{label:"Join Elite",href:"#",actionType:"section"}},{isFeatured:!1,title:"Champion",price:"$199",period:"/month",description:"Built for competitive athletes who need personalized programming and one-on-one coaching.",features:[{title:"Everything in Elite"},{title:"Personal training sessions"},{title:"Custom program design"},{title:"Competition prep support"},{title:"Exclusive athlete events"}],button:{label:"Go Champion",href:"#",actionType:"section"}}]},visualConfig:{}}),"cta-basic":e9({sectionType:"cta",sectionId:"cta-basic",content:{heading:"Ready to transform?",description:"Join FORGE today and get your first week free. No contracts, no pressure—just results.",buttons:[{label:"Claim Free Week",href:"#",actionType:"section"},{label:"View Membership Options",href:"#",actionType:"section"}]},visualConfig:{textAlignment:"split"}}),"cta-background-image":e9({sectionType:"cta",sectionId:"cta-background-image",content:{kicker:"Let's Get Started",heading:"Stop planning. \nStart training.",description:"Try FORGE free for a week. No commitments, no pressure—just see if it clicks. We think it will.",backgroundImage:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/woman-deadlifting-gym.png?w=1920&h=1080&fit=crop",alt:"Woman performing a barbell deadlift in a gym."},buttons:[{label:"Start Free Week",href:"#",actionType:"section"},{label:"Schedule Tour",href:"#",actionType:"section"}]},visualConfig:{textAlignment:"center"}}),"contact-form-image":e9({sectionType:"contact",sectionId:"contact-form-image",content:{kicker:"Get Started",heading:"Ready to transform?",description:"Drop us a message and we'll get back to you within 24 hours.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"Tell us about your fitness goals",submitButtonLabel:"Send Message",formConfig:{successTitle:"Message Received!",successMessage:"We'll be in touch soon.",successButtonLabel:"Send another message"},image:{src:"https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800&q=80",alt:"Athlete training in modern gym"}},visualConfig:{imagePosition:"right"}}),"contact-form-map":e9({sectionType:"contact",sectionId:"contact-form-map",content:{kicker:"Get Started",heading:"Ready to transform?",description:"Drop us a message and we'll get back to you within 24 hours.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"Tell us about your fitness goals",submitButtonLabel:"Send Message",formConfig:{successTitle:"Message Received!",successMessage:"We'll be in touch soon.",successButtonLabel:"Send another message"},map:{address:"55 Water Street, Vancouver, BC V6B 1A1"}},visualConfig:{mapPosition:"right",mapType:"roadmap",zoom:15}}),"faq-accordion":e9({sectionType:"faq",sectionId:"faq-accordion",content:{kicker:"FAQ",heading:"Common Questions",description:"Everything you need to know about training at FORGE.",buttons:[],items:[{question:"What's included in my membership?",answer:"All memberships include 24/7 facility access, premium equipment, and community support. Elite and Champion tiers add classes, coaching, and recovery amenities."},{question:"Can I try before I commit?",answer:"Absolutely. We offer a free week trial so you can experience everything FORGE has to offer before making a decision."},{question:"Do you offer personal training?",answer:"Yes! Our Champion membership includes personal training sessions, or you can add sessions to any membership tier."},{question:"What are your hours?",answer:"We're open 24/7 for all members. Staffed hours are 5am-10pm Monday through Friday, and 7am-8pm on weekends."}]},visualConfig:{contentAlignment:"center"}}),"showcase-grid":e9({sectionType:"showcase",sectionId:"showcase-grid",content:{kicker:"Trusted By",heading:"Elite brands train here",description:"We're proud to partner with leading fitness and sports brands.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-1.svg",alt:"Logo 1"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-2.svg",alt:"Logo 2"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-3.svg",alt:"Logo 3"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-4.svg",alt:"Logo 4"}],logoTags:["fitness","gym"]},visualConfig:{contentAlignment:"center",itemSize:"md"}}),"text-basic":e9({sectionType:"text",sectionId:"text-basic",content:{kicker:"Our Philosophy",heading:"Strength isn't given. It's earned.",description:"At FORGE, we believe that real progress comes from consistent effort, expert guidance, and a community that pushes you to be better every day."},visualConfig:{alignment:"center"}}),"metrics-basic":e9({sectionType:"metrics",sectionId:"metrics-basic",content:{kicker:"By The Numbers",heading:"Results that speak for themselves.",description:"Our members don't just train—they transform.",items:[{metric:"5,000+",title:"Active Members",description:"A thriving community of dedicated athletes"},{metric:"15",title:"Expert Coaches",description:"Certified professionals guiding your journey"},{metric:"24/7",title:"Facility Access",description:"Train on your schedule, not ours"},{metric:"98%",title:"Member Retention",description:"Once you join, you won't want to leave"}]},visualConfig:{}}),"location-map":e9({sectionType:"location",sectionId:"location-map",content:{address:"55 Water Street, Vancouver, BC V6B 1A1"},visualConfig:{mapType:"roadmap",zoom:15}}),"location-text-and-map":e9({sectionType:"location",sectionId:"location-text-and-map",content:{kicker:"Visit us",heading:"Find us nearby \n and stop by today.",description:"Use the map to get directions and visit our location.",map:{address:"55 Water Street, Vancouver, BC V6B 1A1"}},visualConfig:{mapPositionOptions:{mapPosition:"right"},mapType:"roadmap",zoom:15,fillViewportOptions:{fillViewport:!1}}}),"footer-logo-nav":e9({sectionType:"footer",sectionId:"footer-logo-nav",content:{logo:{type:"text",text:"FORGE"},navItems:[{label:"Home",href:"/",actionType:"page"},{label:"Programs",href:"/programs",actionType:"page"},{label:"Trainers",href:"/trainers",actionType:"page"},{label:"Schedule",href:"/schedule",actionType:"page"},{label:"Join",href:"/join",actionType:"page"}],legalLinks:[{label:"Privacy Policy",href:"/privacy",actionType:"page"},{label:"Terms of Service",href:"/terms",actionType:"page"}],copyright:"© 2026 FORGE Fitness. All rights reserved."},visualConfig:{showLegalLinks:!0}})},te={colorSchemeId:e7.colorSchemes[0].id,themeColorOverride:"#171717",typographyStyleId:"modern",content:{header:e8["header-marketer"],content:[e8["banner-bento-grid"],e8["feature-bento-grid"],e8["gallery-grid"],e8["text-basic"],e8["showcase-grid"],e8["metrics-basic"],e8["testimonial-carousel"],e8["team-grid"],e8["pricing-table"],e8["faq-accordion"],e8["cta-background-image"],e8["contact-form-image"],e8["contact-form-map"],e8["location-text-and-map"],e8["location-map"]],footer:e8["footer-logo-nav"]}},tt=T({id:"urban-edge",name:"Urban Edge",description:"A bold, high-energy design featuring near-black primary tones paired with electric orange accents. Sharp corners and modern typography create a powerful, athletic presence. Perfect for gyms, fitness studios, sports brands, and urban lifestyle businesses seeking maximum visual impact and dynamic energy.",previewImage:"https://example.com/image.jpg",sections:e6,themeConfig:e7,previewSchema:te,tags:["sports","entertainment","personal"],isPublished:!0,examples:e8}),ta={banner:{"banner-text-and-background-image":{},"banner-text-and-image":{}},feature:{"feature-grid":{},"feature-bento-grid":{},"feature-carousel":{},"feature-carousel-accordion":{}},testimonial:{"testimonial-grid":{}},gallery:{"gallery-grid":{}},team:{"team-grid":{}},cta:{"cta-basic":{overrides:{textAlignment:"center"}},"cta-background-image":{overrides:{textAlignment:"center"}}},contact:{"contact-form-text":{},"contact-form-map":{}},faq:{"faq-accordion":{}},pricing:{"pricing-table":{}},showcase:{"showcase-grid":{}},text:{"text-basic":{}},metrics:{"metrics-basic":{}},location:{"location-map":{},"location-text-and-map":{}},header:{"header-basic":{}},footer:{"footer-logo-highlight":{}}},to={colorSchemes:eo([D({id:"warm-earthy",name:"Warm Earthy",category:"preferred",description:"A warm, earthy color palette featuring deep brown primary tones paired with muted forest green secondary accents. The primary scale offers rich, low-brightness brown solid colors that create a grounded, natural aesthetic. The secondary provides organic green tones that complement the warmth of the primary. High contrast between light backgrounds and dark solid colors establishes clear visual hierarchy. Ideal for florists, garden centers, nurseries, and nature-focused businesses seeking an organic, premium feel.",colorPalette:{primary:{colorSet:et("#405F40"),isDynamic:!0},secondary:{colorSet:et("#F5EDE1"),isDynamic:!0},accent:{colorSet:et("#C2703E"),isThemeColor:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.sand,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"accent",scale:"solid"},foregroundColor:{tint:"secondary",contrast:7}},secondary:{backgroundColor:{category:"secondary",scale:"interactive-bg-2"}}}}},globalColorOverrides:{background:{base:{category:"secondary",scale:"interactive-bg"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}}),D({id:"rich-contrast",name:"Rich Contrast",category:"preferred",description:"A soft, elegant color palette featuring warm blush primary tones paired with deep navy secondary accents. The primary blush provides a gentle, sophisticated base while the secondary navy adds depth and contrast. The warm primary creates an inviting, feminine aesthetic while the dark secondary grounds the design with bold accents. Clear brightness contrast between light backgrounds and deep solid colors. Perfect for upscale florists, boutique event planners, and premium lifestyle brands seeking refined elegance.",colorPalette:{primary:{colorSet:et("#232335"),isDynamic:!0},secondary:{colorSet:et("#EBCEC0"),isDynamic:!0},accent:{colorSet:et("#C96A5A"),isThemeColor:!0},neutral:{colorSet:et(l.referenceBaseColors.neutral.sand,{neutral:!0})}},themableComponentColorOverrides:{button:{"flat-button":{primary:{backgroundColor:{category:"accent",scale:"solid"},foregroundColor:{tint:"secondary",contrast:7}},secondary:{backgroundColor:{category:"secondary",scale:"interactive-bg-2"}}}}},globalColorOverrides:{background:{base:{category:"secondary",scale:"interactive-bg-3"},featured:{category:"accent",scale:"solid"}},foreground:{strong:{tint:"neutral",contrast:9},medium:{tint:"neutral",contrast:7},light:{tint:"neutral",contrast:5},accent:{tint:"theme",contrast:7},divider:{tint:"neutral",contrast:5,autoAdjust:"loose"},border:{tint:"neutral",contrast:2,autoAdjust:"loose"}}}})]),typographyStyles:["elegant-serif","modern","bricolage-grotesque","playfair-source","nunito","oswald-source","space-grotesk","unbounded-geist","albert-sans","libre-baskerville","fraunces-open-sans","work-sans-rubik","lexend","figtree","crimson-pro","syne-geist","montagu-slab"],iconStyles:["vinyl","material"],defaultTypographyStyleId:"elegant-serif",defaultIconStyleId:"vinyl",themableComponentOverrides:{button:{variant:"flat-button"}}},ti=[{platform:"facebook",url:"https://www.facebook.com",label:"Facebook"},{platform:"instagram",url:"https://www.instagram.com",label:"Instagram"},{platform:"pinterest",url:"https://www.pinterest.com",label:"Pinterest"}],tn=_(ta),tr={"header-basic":tn({sectionType:"header",sectionId:"header-basic",content:{navItems:[{type:"link",link:{label:"Home",actionType:"page",href:"/"}},{type:"dropdown",label:"Services",navItems:[{label:"Landscape Design",actionType:"page",href:"/services/landscape-design"},{label:"Garden Maintenance",actionType:"page",href:"/services/garden-maintenance"}]},{type:"link",link:{label:"About",actionType:"page",href:"/about"}},{type:"link",link:{label:"Contact",actionType:"page",href:"/contact"}},{type:"link",link:{label:"Blog",actionType:"page",href:"/blog"}}],logo:{type:"image",src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/development/website-builder-v2/florora-logo.svg",alt:"Florora"},buttons:[{label:"Sign In",href:"/sign-in",actionType:"page"}],socialLinks:ti},visualConfig:{showButtons:!1,showSocial:!0}}),"banner-text-and-background-image":tn({sectionType:"banner",sectionId:"banner-text-and-background-image",content:{kicker:"Garden",heading:"Create your \n dream garden with vibrant blooms.",description:"Transform your outdoor space into a vibrant sanctuary. From lush blooms to timeless layouts, we'll bring beauty and balance to your garden.",buttons:[{label:"Get Started",href:"#get-started",actionType:"section"}],backgroundImage:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770075103972-jzfmpg.png?w=1920",alt:"Professional gardener tending to plants in a beautiful garden"}},visualConfig:{fillViewport:!0}}),"banner-text-and-image":tn({sectionType:"banner",sectionId:"banner-text-and-image",content:{kicker:"Our Services",heading:"The Gardening \nExperts You Can Trust",description:"We bring years of expertise, a love for nature, and a commitment to quality to every project.",buttons:[{label:"Learn More",href:"#",actionType:"section"}],image:{src:"https://images.unsplash.com/photo-1585320806297-9794b3e4eeae?w=1920&h=1080&fit=crop",alt:"Professional landscaping work in progress"}},visualConfig:{imagePositionOptions:{imagePosition:"right",hasImagePadding:!0},fillViewportOptions:{fillViewport:!1}}}),"feature-grid":tn({sectionType:"feature",sectionId:"feature-grid",content:{description:"We bring years of expertise, a love for nature, and a commitment to quality to every project. Whether it's a small garden or a full landscape transformation, we ensure exceptional results.",kicker:"Why choose us",heading:"Transform Your \nOutdoor Space with \nOur Expert Care",buttons:[{label:"Talk to an expert",href:"#",actionType:"section"}],items:[{title:"Landscape Design",description:"Stunning, tailored gardens and outdoor spaces designed for you, creating lasting natural beauty.",image:{src:"https://images.unsplash.com/photo-1558904541-efa843a96f01?w=800",alt:"Landscape Design"}},{title:"Lawn & Plant Care",description:"Expert care to keep your lawn and plants lush year-round, ensuring optimal growth patterns.",image:{src:"https://images.unsplash.com/photo-1592595896551-12b371d546d5?w=800&q=80",alt:"Lawn & Plant Care"}},{title:"Sustainable Gardening",description:"Low-maintenance, eco-friendly gardens that save water, promoting environmental harmony naturally.",image:{src:"https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=800&q=80",alt:"Sustainable Gardening"}}]},visualConfig:{imageOptions:{showImages:!0,isCaptionInside:!1}}}),"feature-bento-grid":tn({sectionType:"feature",sectionId:"feature-bento-grid",content:{kicker:"Why choose us",heading:"Transform Your \nOutdoor Space with \nOur Expert Care",description:"We bring years of expertise, a love for nature, and a commitment to quality to every project. Whether it's a small garden or a full landscape transformation, we ensure exceptional results.",buttons:[{label:"Talk to an expert",href:"#",actionType:"section"}],items:[{type:"text",title:"Seasonal Cleanup & Landscaping",description:"Spring and fall leaf removal, debris clearing, mulching, and small landscaping enhancements such as planting or edging beds.",isInverted:!1},{type:"text",title:"Aeration & Overseeding",description:"Core aeration to improve soil oxygen and water absorption, followed by overseeding to thicken the turf and repair bare patches.",isInverted:!1},{type:"image",src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770076933831-789tv5.png?w=800",alt:"Seasonal Cleanup & Landscaping"},{type:"image",src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770076902666-1iqwf1.png?w=800&q=80",alt:"Professional landscaper at work"},{type:"text",title:"Fertilization & Weed Control",description:"Scheduled nutrient applications and targeted weed treatments to promote lush growth and prevent invasive species.",isInverted:!1},{type:"text",title:"Garden Maintenance",description:"Regular pruning, trimming, and upkeep to keep your garden looking its best throughout the seasons.",isInverted:!0}]},visualConfig:{}}),"feature-carousel":tn({sectionType:"feature",sectionId:"feature-carousel",content:{items:[{title:"Guided onboarding",kicker:"Step 1",description:"Personalized setup paths enable every role to get productive on day one.",image:{src:"https://images.unsplash.com/photo-1545239351-1141bd82e8a6?w=1600&q=80",alt:"Team collaborating during onboarding"},buttons:[{label:"Onboarding",actionType:"section",href:"#onboarding"}]},{title:"Workflow automations",kicker:"Step 2",description:"Automate repetitive handoffs with adaptable playbooks built for your processes.",image:{src:"https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=1600&q=80",alt:"Automated workflow dashboard on a laptop"},buttons:[{label:"Automations",actionType:"section",href:"#automations"}]},{title:"Actionable insights",kicker:"Step 3",description:"Real-time dashboards surface trends and recommended actions before issues appear.",image:{src:"https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=800&q=80",alt:"Analytics dashboard showing insights"},buttons:[{label:"Insights",actionType:"section",href:"#insights"}]}]},visualConfig:{}}),"feature-carousel-accordion":tn({sectionType:"feature",sectionId:"feature-carousel-accordion",content:{heading:"Our Services",description:"We offer a wide range of services to help you create the perfect garden. From garden design to garden maintenance, we have you covered.",items:[{title:"Expert Garden Design",description:"Our team of experienced designers will work with you to create a garden that reflects your style and meets your needs.",image:{src:"https://images.unsplash.com/photo-1558904541-efa843a96f01?w=1600&q=80",alt:"Beautiful garden design"}},{title:"Sustainable Practices",description:"We use eco-friendly methods and native plants to create gardens that are both beautiful and environmentally responsible.",image:{src:"https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=1600&q=80",alt:"Sustainable garden practices"}},{title:"Ongoing Maintenance",description:"Keep your garden looking its best year-round with our comprehensive maintenance services.",image:{src:"https://images.unsplash.com/photo-1530836369250-ef72a3f5cda8?w=1600&q=80",alt:"Garden maintenance service"}},{title:"Expert Garden Design",description:"Our team of experienced designers will work with you to create a garden that reflects your style and meets your needs.",image:{src:"https://images.unsplash.com/photo-1558904541-efa843a96f01?w=1600&q=80",alt:"Beautiful garden design"}},{title:"Sustainable Practices",description:"We use eco-friendly methods and native plants to create gardens that are both beautiful and environmentally responsible.",image:{src:"https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=1600&q=80",alt:"Sustainable garden practices"}}]},visualConfig:{}}),"testimonial-grid":tn({sectionType:"testimonial",sectionId:"testimonial-grid",content:{kicker:"Testimonials",heading:"See What Our\nCustomers Are Saying",buttons:[{label:"See more testimonials",href:"#",actionType:"section"}],items:[{quote:"Our backyard has never looked so good! The team turned our outdoor area into a lush paradise, and we couldn't be happier!",name:"Sarah Johnson",title:"Small Business Owner",image:{src:"https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop",alt:"Sarah Johnson"}},{quote:"The attention to detail and professionalism was outstanding. They transformed our vision into reality beyond our expectations!",name:"Michael Chen",title:"Marketing Director",image:{src:"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop",alt:"Michael Chen"}},{quote:"Exceptional service from start to finish! The results exceeded what we hoped for, and the process was smooth and stress-free.",name:"Emily Rodriguez",title:"Restaurant Owner",image:{src:"https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&h=100&fit=crop",alt:"Emily Rodriguez"}},{quote:"A fantastic experience! The team was knowledgeable, friendly, and delivered top-notch results that truly enhanced our property.",name:"David Lee",title:"Entrepreneur",image:{src:"https://images.unsplash.com/photo-1527980965255-d3b416303d12?w=100&h=100&fit=crop",alt:"David Lee"}}]},visualConfig:{}}),"gallery-grid":tn({sectionType:"gallery",sectionId:"gallery-grid",content:{kicker:"Our work",heading:"Transform Your \nOutdoor Space with \nOur Expert Care",description:"We bring years of expertise, a love for nature, and a commitment to quality to every project. Whether it's a small garden or a full landscape transformation, we ensure exceptional results.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770077002456-rpo7tx.png?w=800",alt:"Beautiful mansion with pool"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770078019014-d1u620.png?w=800&q=80",alt:"Garden pathway"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770078065389-q1jdu4.png?w=800&q=80",alt:"Professional landscaper at work"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770078076143-7jhouf.png?w=800&q=80",alt:"Garden maintenance"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770078253004-9g6ni6.png?w=800&q=80",alt:"Outdoor landscaping"}]},visualConfig:{}}),"team-grid":tn({sectionType:"team",sectionId:"team-grid",content:{kicker:"Meet the Team",heading:"Our Passionate \nGardening Experts",description:"Our team of dedicated professionals brings a wealth of knowledge and a love for nature to every project. Get to know the experts who will transform your outdoor space.",items:[{name:"Sarah Mitchell",role:"Founder & Lead Designer",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770072206783-u06icw.png?w=400&h=400&fit=crop",alt:"Sarah Mitchell"},description:"Sarah brings over 20 years of landscape design experience and a passion for creating outdoor spaces that inspire."},{name:"Marcus Chen",role:"Head Horticulturist",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770072490592-fclt9d.png?w=400&h=400&fit=crop",alt:"Marcus Chen"},description:"Marcus specializes in plant science and sustainable gardening practices, ensuring every garden thrives naturally."},{name:"Emily Rodriguez",role:"Garden Care Manager",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770074373284-uaacsb.png?w=400&h=400&fit=crop",alt:"Emily Rodriguez"},description:"Emily leads our maintenance team with meticulous attention to detail and a genuine love for nurturing plants."},{name:"James Thompson",role:"Landscape Architect",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770074543573-i8eh83.png?w=400&h=400&fit=crop",alt:"James Thompson"},description:"James transforms outdoor spaces with innovative designs that balance aesthetics with functionality and sustainability."},{name:"Olivia Park",role:"Irrigation Specialist",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770074829389-ej3i6m.png?w=400&h=400&fit=crop",alt:"Olivia Park"},description:"Olivia designs efficient watering systems that conserve water while keeping landscapes lush and healthy year-round."},{name:"Daniel Williams",role:"Senior Gardener",image:{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/websites/preview-media/1770074981627-bomu7g.png?w=400&h=400&fit=crop",alt:"Daniel Williams"},description:"Daniel brings hands-on expertise to every project, from planting to pruning, with over 15 years of experience."}]},visualConfig:{showImages:!0}}),"cta-basic":tn({sectionType:"cta",sectionId:"cta-basic",content:{heading:"Get the Yard You Want Today!",description:"Transform your outdoor space into a vibrant sanctuary. From lush blooms to timeless layouts, we'll bring beauty and balance to your garden.",buttons:[{label:"Talk to an Expert",href:"#",actionType:"section"},{label:"Get a Free Quote",href:"#",actionType:"section"}]},visualConfig:{textAlignment:"center"}}),"cta-background-image":tn({sectionType:"cta",sectionId:"cta-background-image",content:{heading:"Get the Yard You Want Today!",description:"Transform your outdoor space into a vibrant sanctuary.",backgroundImage:{src:"https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=1920",alt:"Professional gardener tending to plants in a beautiful garden"},buttons:[{label:"Talk to an Expert",href:"#",actionType:"section"},{label:"Get a Free Quote",href:"#",actionType:"section"}]},visualConfig:{textAlignment:"center"}}),"contact-form-text":tn({sectionType:"contact",sectionId:"contact-form-text",content:{kicker:"Contact us",heading:"Send us a message",description:"We would love to hear from you",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"Your Message",submitButtonLabel:"Send Message",formConfig:{contactEmail:"hello@example.com",contactPhone:"+1 (555) 123-4567",contactAddress:"123 Main St, City, Country",successTitle:"Thank you!",successMessage:"We'll get back to you soon.",successButtonLabel:"Send another message"}},visualConfig:{contentAlignment:"split"}}),"text-basic":tn({sectionType:"text",sectionId:"text-basic",content:{kicker:"Our work",heading:"Transform Your Outdoor Space with Our Expert Care",description:"We bring years of expertise, a love for nature, and a commitment to quality to every project. Whether it's a small garden or a full landscape transformation, we ensure exceptional results."},visualConfig:{alignment:"split"}}),"faq-accordion":tn({sectionType:"faq",sectionId:"faq-accordion",content:{kicker:"FAQ",heading:"Frequently Asked Questions",description:"Have questions about our services? Find answers to the most common inquiries below.",buttons:[{label:"Contact Us",href:"#contact",actionType:"section"}],items:[{question:"What services do you offer for landscape design and maintenance?",answer:"We offer a variety of services for landscape design and maintenance, including custom garden design, lawn care, tree and shrub planting, irrigation system installation, and seasonal clean-up. Our team is dedicated to creating beautiful outdoor spaces that suit your needs and preferences."},{question:"What is the best time to plant a garden?",answer:"The best time to plant a garden depends on your location and the types of plants you want to grow. Generally, spring and fall are ideal for most plants, as temperatures are moderate and rainfall is more consistent. However, some plants thrive in summer or winter, so it's important to research the specific requirements of your chosen plants."},{question:"How do I maintain my landscape throughout the year?",answer:"Maintaining your landscape throughout the year involves regular tasks such as mowing, watering, fertilizing, pruning, and mulching. In spring, focus on planting and fertilizing. Summer requires consistent watering and pest control. Fall is the time for cleanup and preparation for winter. Winter maintenance includes protecting plants from frost and planning for the next growing season."},{question:"What types of plants thrive in my area?",answer:"The types of plants that thrive in your area depend on your climate zone, soil type, and sun exposure. Native plants are often the best choice as they are adapted to local conditions and require less maintenance. Consider consulting with a local nursery or landscape professional to identify plants that will flourish in your specific environment."},{question:"How can I create a sustainable garden?",answer:"Creating a sustainable garden involves choosing native plants, using organic fertilizers and pest control methods, conserving water through efficient irrigation systems and mulching, composting yard waste, and encouraging beneficial insects and wildlife. These practices help create a healthy ecosystem while reducing environmental impact."}]},visualConfig:{contentAlignment:"split"}}),"pricing-table":tn({sectionType:"pricing",sectionId:"pricing-table",content:{kicker:"Pricing",heading:"Simple, Transparent \nPricing Plans",description:"Choose the plan that fits your garden needs. From basic maintenance to full landscape transformations, we have options for every budget.",items:[{isFeatured:!1,title:"Basic Care",price:"$99/mo",features:[{title:"Weekly lawn mowing"},{title:"Edge trimming"},{title:"Debris cleanup"},{title:"Monthly plant inspection"}],description:"Essential lawn care to keep your yard looking neat and tidy all season long.",button:{label:"Get Started",href:"#contact",actionType:"section"}},{isFeatured:!0,badgeLabel:"Most popular",title:"Complete Garden",price:"$249/mo",features:[{title:"Everything in Basic Care"},{title:"Seasonal planting"},{title:"Fertilization & weed control"},{title:"Shrub & hedge trimming"},{title:"Irrigation system checks"}],description:"Comprehensive care for a thriving, beautiful garden that impresses year-round.",button:{label:"Get Started",href:"#contact",actionType:"section"}},{isFeatured:!1,title:"Premium Estate",price:"$499/mo",features:[{title:"Everything in Complete Garden"},{title:"Custom landscape design"},{title:"Hardscape maintenance"},{title:"Outdoor lighting care"},{title:"Priority scheduling"},{title:"Dedicated account manager"}],description:"White-glove service for estate properties requiring meticulous attention to every detail.",button:{label:"Contact Us",href:"#contact",actionType:"section"}}]},visualConfig:{}}),"showcase-grid":tn({sectionType:"showcase",sectionId:"showcase-grid",content:{kicker:"Clients",heading:"We work with the top companies",description:"With years of experience and a love for nature, we ensure quality in every project, from small gardens to full landscape makeovers.",items:[{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-1.svg",alt:"Logo 1"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-2.svg",alt:"Logo 2"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-3.svg",alt:"Logo 3"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-4.svg",alt:"Logo 4"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-5.svg",alt:"Logo 5"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-6.svg",alt:"Logo 6"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-7.svg",alt:"Logo 7"},{src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/production/infinite-design/example-logos/color/logo-8.svg",alt:"Logo 8"}],logoTags:["restaurant","cafe"]},visualConfig:{contentAlignment:"split",itemSize:"md"}}),"metrics-basic":tn({sectionType:"metrics",sectionId:"metrics-basic",content:{kicker:"Expert Lawn Care",heading:"Transform Your Outdoor Space with Our Expert Lawn Care",description:"We bring years of experience and a passion for healthy outdoor spaces. From routine lawn care to full transformations, we deliver reliable, high-quality results for every property.",buttons:[{label:"Talk to an Expert",href:"#contact",actionType:"section"}],items:[{metric:"400+",title:"Lawns restored",description:"We've turned patchy grass into vibrant lawns for hundreds of clients."},{metric:"600%",title:"Increase in property appeal",description:"Clients enjoy enhanced curb appeal and outdoor enjoyment after working with our landscaping team."},{metric:"10k",title:"Square feet maintained",description:"We care for everything from small yards to large outdoor spaces."},{metric:"200+",title:"5-star reviews",description:"Homeowners trust us for reliable service, expert guidance, and consistently beautiful results."}]},visualConfig:{}}),"contact-form-map":tn({sectionType:"contact",sectionId:"contact-form-map",content:{kicker:"Contact us",heading:"Let's make your garden flourish",description:"Share your project details and we'll follow up quickly.",nameLabel:"Your Name",emailLabel:"Email Address",messageLabel:"Tell us about your landscape",submitButtonLabel:"Send Message",formConfig:{successTitle:"Thank you!",successMessage:"We'll get back to you soon.",successButtonLabel:"Send another message"},map:{address:"1600 Amphitheatre Parkway, Mountain View, CA 94043"}},visualConfig:{mapPosition:"right",mapType:"roadmap",zoom:15}}),"location-map":tn({sectionType:"location",sectionId:"location-map",content:{address:"1600 Amphitheatre Parkway, Mountain View, CA 94043"},visualConfig:{mapType:"roadmap",zoom:15}}),"location-text-and-map":tn({sectionType:"location",sectionId:"location-text-and-map",content:{kicker:"Visit us",heading:"Find us nearby \n and stop by today.",description:"Use the map to get directions and visit our location.",map:{address:"1600 Amphitheatre Parkway, Mountain View, CA 94043"}},visualConfig:{mapPositionOptions:{mapPosition:"right"},fillViewportOptions:{fillViewport:!1},mapType:"roadmap",zoom:15}}),"footer-logo-highlight":tn({sectionType:"footer",sectionId:"footer-logo-highlight",content:{logo:{type:"image",src:"https://rjdavx8ozyznxeyh.public.blob.vercel-storage.com/development/website-builder-v2/florora-logo-inverte