	.unpublished-container {
		display: flex;
		height: 100dvh;
		width: 100%;
		flex-direction: column;
		background-color: #f9fafb;
		padding: 2.5rem 1rem;
		box-sizing: border-box;
		margin: 0;
		overflow: hidden;
	}
	.unpublished-center {
		display: flex;
		flex: 1;
		align-items: center;
		justify-content: center;
		min-height: 0;
		width: 100%;
	}
	.unpublished-content {
		text-align: center;
		color: rgba(0, 0, 0, 0.7);
		width: 100%;
		max-width: 100%;
		box-sizing: border-box;
		padding: 0 1rem;
	}
	.unpublished-title {
		font-size: 1.875rem;
		font-weight: 600;
		margin: 0;
		word-wrap: break-word;
		overflow-wrap: break-word;
